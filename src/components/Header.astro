---
// src/components/Header.astro
import { WERNEX, NAV_LINKS } from '../data/business';
interface Props { active?: string; }
const { active = '' } = Astro.props;
const phoneSvg = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16"><path d="M3.654 1.328a.678.678 0 0 0-1.015-.063L1.605 2.3c-.483.484-.661 1.169-.45 1.77a17.6 17.6 0 0 0 4.168 6.608 17.6 17.6 0 0 0 6.608 4.168c.601.211 1.286.033 1.77-.45l1.034-1.034a.678.678 0 0 0-.063-1.015l-2.307-1.794a.68.68 0 0 0-.58-.122l-2.19.547a1.75 1.75 0 0 1-1.657-.459L5.482 8.062a1.75 1.75 0 0 1-.46-1.657l.548-2.19a.68.68 0 0 0-.122-.58z"/></svg>`;
---
<nav class="nav">
  <div class="container nav__inner">
    <a href="index.html" class="nav__logo nav__logo--img">
      <img src="images/Logo.webp" alt={WERNEX.legalName} class="nav__logo-img" width="189" height="126" fetchpriority="high" decoding="async">
    </a>
    <div class="nav__links">
      {NAV_LINKS.map((l) => (
        <a href={l.href} class={active === l.href ? 'active' : undefined}>{l.label}</a>
      ))}
    </div>
    <a href={`tel:${WERNEX.phoneTel}`} class="nav__phone">
      <Fragment set:html={phoneSvg} />
      {WERNEX.phone}
    </a>
    <a href="contact.html" class="btn btn--primary btn--sm nav__cta">Free Quote</a>
    <button class="nav__hamburger" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </button>
  </div>
  <div class="nav__mobile">
    {NAV_LINKS.map((l) => (
      <a href={l.href}>{l.label === 'Schedule Appt' ? 'Contact' : l.label}</a>
    ))}
    <a href={`tel:${WERNEX.phoneTel}`} class="mobile-phone">📞 {WERNEX.phone}</a>
  </div>
</nav>
