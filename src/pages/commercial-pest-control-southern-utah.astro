        <div class="reveal"><div style="font-size:2.5rem;">✅</div><p style="color:rgba(255,255,255,0.8);margin-top:8px;">QualityPro Certified</p></div>
        <div class="reveal"><div style="font-size:2.5rem;">📋</div><p style="color:rgba(255,255,255,0.8);margin-top:8px;">NPMA Member</p></div>
        <div class="reveal"><div style="font-size:2.5rem;">🌿</div><p style="color:rgba(255,255,255,0.8);margin-top:8px;">EPA-Compliant</p></div>
