---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Commercial Pest Control in Southern Utah — Restaurants, Offices & Warehouses | Wernex';
const description = 'Wernex provides commercial pest control for Southern Utah businesses — restaurants, offices, warehouses, hotels, and retail. Compliance docs, flexible scheduling, and same-day service. Call (435) 673-9503.';
const canonical = 'https://www.wernexpestcontrol.com/commercial-pest-control-southern-utah.html';
const active = '';
const og = { "og:title": 'Commercial Pest Control Southern Utah | Wernex', "og:description": 'Wernex provides commercial pest control for Southern Utah businesses — restaurants, offices, warehouses, hotels, and retail. Compliance docs, flexible scheduling, and same-day service. Call (435) 673-9503.', "og:type": 'website', "og:url": 'https://www.wernexpestcontrol.com/commercial-pest-control-southern-utah.html', "og:locale": 'en_US', "og:site_name": 'Wernex Termite & Pest Control' };
const schema = `{
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "LocalBusiness",
        "@id": "https://www.wernexpestcontrol.com/#business",
        "name": "Wernex Termite & Pest Control, Inc.",
        "url": "https://www.wernexpestcontrol.com/",
        "telephone": "+1-435-673-9503",
        "email": "wernexpestcontrol@gmail.com",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "6097 Dry Fork Canyon Rd",
          "addressLocality": "Vernal",
          "addressRegion": "UT",
          "postalCode": "84078",
          "addressCountry": "US"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": 40.4555,
          "longitude": -109.5287
        },
        "areaServed": [{"@type":"City","name":"St. George"},{"@type":"City","name":"Washington"},{"@type":"City","name":"Hurricane"},{"@type":"City","name":"Ivins"},{"@type":"City","name":"Santa Clara"},{"@type":"City","name":"LaVerkin"},{"@type":"City","name":"Cedar City"}],
        "priceRange": "$",
        "image": "https://www.wernexpestcontrol.com/images/Logo.webp",
        "logo": "https://www.wernexpestcontrol.com/images/Logo.webp",
        "description": "Commercial pest control for Southern Utah businesses. Restaurants, offices, warehouses, hotels, and retail. Compliance documentation and flexible scheduling."
      },
      {
        "@type": "FAQPage",
        "@id": "https://www.wernexpestcontrol.com/commercial-pest-control-southern-utah.html#faq",
        "mainEntity": [{"@type":"Question","name":"Does Wernex provide pest control for restaurants in St. George?","acceptedAnswer":{"@type":"Answer","text":"Yes. Wernex provides restaurant-specific pest management programs that meet UDAF and health department requirements. We provide compliance documentation for inspections, offer after-hours service to avoid disrupting operations, and respond same-day for emergencies. Call (435) 673-9503."}},{"@type":"Question","name":"What industries does Wernex serve commercially?","acceptedAnswer":{"@type":"Answer","text":"Wernex serves restaurants, hotels, vacation rentals, retail stores, offices, medical facilities, warehouses, food processing plants, storage facilities, and multi-unit residential properties throughout Southern Utah."}},{"@type":"Question","name":"Does Wernex provide compliance documentation?","acceptedAnswer":{"@type":"Answer","text":"Yes. Wernex provides detailed service reports, pesticide application records, and compliance certificates for health inspections, property management audits, and corporate pest management requirements."}},{"@type":"Question","name":"Can Wernex service my business after hours?","acceptedAnswer":{"@type":"Answer","text":"Yes. Wernex offers flexible scheduling including early morning, evening, and weekend service appointments to minimize disruption to your business operations."}},{"@type":"Question","name":"How much does commercial pest control cost in Southern Utah?","acceptedAnswer":{"@type":"Answer","text":"Commercial pricing depends on facility size, pest pressure, service frequency, and industry requirements. Wernex offers free commercial assessments and competitive pricing. Call (435) 673-9503 for a custom quote."}}]
      }
    ]
  }`;
---
<BaseLayout title={title} description={description} canonical={canonical} og={og} schema={schema} active={active}>
<section class="section--dark" style="padding-top:140px;">
    <div class="container">
      <span class="section-label">Commercial Services</span>
      <h1>Commercial Pest Control for Southern Utah Businesses</h1>
      <p style="max-width:70ch;color:rgba(255,255,255,0.85);font-size:1.1rem;margin-top:16px;line-height:1.7;">
        Wernex Termite &amp; Pest Control delivers custom commercial pest management programs for businesses throughout <a href="pest-control-southern-utah.html" style="color:var(--lime);text-decoration:underline;">Southern Utah</a>. From restaurants and hotels in St. George to warehouses in Hurricane and <a href="pest-control-vacation-rentals-southern-utah.html" style="color:var(--lime);text-decoration:underline;">vacation rental pest control near Zion</a>, Wernex provides health-code-compliant pest control with compliance documentation, flexible after-hours scheduling, and same-day emergency response. All technicians are state-licensed and EPA-compliant. BBB A+ Accredited and QualityPro Certified. Call (435) 673-9503.
      </p>
      <div style="margin-top:28px;display:flex;gap:14px;flex-wrap:wrap;">
        <a href="contact.html" class="btn btn--primary">Get a Free Quote</a>
        <a href="tel:+14356739503" class="btn btn--outline" style="border-color:var(--lime);color:var(--lime);">📞 (435) 673-9503</a>
      </div>
    </div>
  </section>

  <section class="section" style="padding:32px 0;">
    <div class="container" style="display:flex;flex-wrap:wrap;gap:24px;justify-content:center;">
      <div class="hero__badge"><div class="hero__badge-icon">⭐</div><span>4.5-Star Rated</span></div>
      <div class="hero__badge"><div class="hero__badge-icon">🌿</div><span>Eco-Friendly</span></div>
      <div class="hero__badge"><div class="hero__badge-icon">⏱️</div><span>Same-Day Service</span></div>
      <div class="hero__badge"><div class="hero__badge-icon">🔒</div><span>30-Day Guarantee</span></div>
    </div>
  </section>


  <section class="section">
    <div class="container">
      <span class="section-label">Business Protection</span>
      <h2>Why Southern Utah Businesses Choose Wernex</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:40px;margin-top:32px;">
        <div>
          <p style="line-height:1.8;margin-bottom:20px;">A pest sighting in a commercial setting isn't just uncomfortable — it's a liability. For restaurants, it can mean a failed health inspection and a public record that damages your reputation. For hotels and vacation rentals, it means negative reviews and lost bookings. For warehouses and retail, it means contaminated inventory and potential OSHA violations.</p>
          <p style="line-height:1.8;margin-bottom:20px;">Southern Utah's warm climate and rapid commercial growth create persistent pest pressure. Restaurants along St. George Boulevard, new retail in Washington, hotels near I-15 exits, and vacation rentals in the Zion corridor all face unique pest challenges that require more than a generic quarterly spray. Wernex provides <a href="pest-control-southern-utah.html" style="color:var(--green-light);font-weight:600;">pest control services across Southern Utah</a> with programs tailored to each market.</p>
          <p style="line-height:1.8;">Wernex designs custom commercial pest management programs based on your specific industry, facility, and risk profile. We assign a dedicated account manager, provide compliance documentation for every service visit, and offer flexible scheduling that works around your business hours. Our QualityPro certification and BBB A+ accreditation back up over 30 years of commercial pest control experience in Southern Utah.</p>
        </div>
        <div>
          <h3 style="margin-bottom:20px;">Industries We Serve</h3>
          <div style="display:grid;gap:12px;">
            <div class="reveal" style="padding:16px 20px;background:var(--off-white);border-radius:var(--radius);display:flex;align-items:center;gap:14px;">
              <span style="font-size:1.5rem;">🍽️</span><div><strong>Restaurants & Food Service</strong> — Health code compliance, kitchen-safe products</div>
            </div>
            <div class="reveal" style="padding:16px 20px;background:var(--off-white);border-radius:var(--radius);display:flex;align-items:center;gap:14px;">
              <span style="font-size:1.5rem;">🏨</span><div><strong>Hotels & Vacation Rentals</strong> — Guest-safe treatments, between-stay service</div>
            </div>
            <div class="reveal" style="padding:16px 20px;background:var(--off-white);border-radius:var(--radius);display:flex;align-items:center;gap:14px;">
              <span style="font-size:1.5rem;">🏬</span><div><strong>Retail & Office</strong> — Discreet service, after-hours scheduling</div>
            </div>
            <div class="reveal" style="padding:16px 20px;background:var(--off-white);border-radius:var(--radius);display:flex;align-items:center;gap:14px;">
              <span style="font-size:1.5rem;">🏗️</span><div><strong>Warehouses & Industrial</strong> — Rodent exclusion, inventory protection</div>
            </div>
            <div class="reveal" style="padding:16px 20px;background:var(--off-white);border-radius:var(--radius);display:flex;align-items:center;gap:14px;">
              <span style="font-size:1.5rem;">🏥</span><div><strong>Medical & Healthcare</strong> — Sanitary-grade treatments, strict compliance</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <span class="section-label">Our Commercial Program</span>
      <h2>What's Included in a Wernex Commercial Plan</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:24px;margin-top:32px;">
        <div class="reveal" style="background:#fff;border-radius:var(--radius-lg);padding:32px;border:1px solid var(--gray-light);">
          <div style="font-size:2rem;margin-bottom:12px;">🔍</div>
          <h3>Facility Assessment</h3>
          <p style="margin-top:8px;color:var(--text-body);line-height:1.7;">Free on-site inspection identifying pest pressure points, sanitation risks, structural vulnerabilities, and entry points specific to your facility type and location.</p>
        </div>
        <div class="reveal" style="background:#fff;border-radius:var(--radius-lg);padding:32px;border:1px solid var(--gray-light);">
          <div style="font-size:2rem;margin-bottom:12px;">📋</div>
          <h3>Custom IPM Program</h3>
          <p style="margin-top:8px;color:var(--text-body);line-height:1.7;">Integrated Pest Management plan tailored to your industry's regulations, your facility's layout, and the local pest pressure. Monthly, bi-monthly, or quarterly frequencies available.</p>
        </div>
        <div class="reveal" style="background:#fff;border-radius:var(--radius-lg);padding:32px;border:1px solid var(--gray-light);">
          <div style="font-size:2rem;margin-bottom:12px;">📄</div>
          <h3>Compliance Documentation</h3>
          <p style="margin-top:8px;color:var(--text-body);line-height:1.7;">Detailed service reports, pesticide application logs, and compliance certificates delivered after every visit. Ready for health inspectors, property managers, and corporate audits.</p>
        </div>
        <div class="reveal" style="background:#fff;border-radius:var(--radius-lg);padding:32px;border:1px solid var(--gray-light);">
          <div style="font-size:2rem;margin-bottom:12px;">🚨</div>
          <h3>Emergency Response</h3>
          <p style="margin-top:8px;color:var(--text-body);line-height:1.7;">Same-day emergency service for unexpected pest issues. Critical for restaurants before inspections, hotels with guest complaints, and any facility facing a pest-related business interruption.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--dark">
    <div class="container text-center">
      <span class="section-label">Certifications & Trust</span>
      <h2 style="color:var(--white);">Credentials That Matter</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:32px;margin-top:40px;max-width:900px;margin-left:auto;margin-right:auto;">
