---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Pest Control in Hurricane UT — Same-Day Service & Eco-Friendly | Wernex';
const description = 'Wernex Termite & Pest Control serves Hurricane, UT with same-day inspections, eco-friendly treatments, and a 30-day guarantee. Just 20 minutes from St. George. Call (435) 673-9503.';
const canonical = 'https://www.wernexpestcontrol.com/pest-control-hurricane-ut.html';
const active = '';
const og = { "og:title": 'Pest Control in Hurricane UT — Same-Day Service | Wernex', "og:description": 'Wernex Termite & Pest Control serves Hurricane, UT with same-day inspections, eco-friendly treatments, and a 30-day guarantee. Just 20 minutes from St. George. Call (435) 673-9503.', "og:type": 'website', "og:url": 'https://www.wernexpestcontrol.com/pest-control-hurricane-ut.html', "og:locale": 'en_US', "og:site_name": 'Wernex Termite & Pest Control' };
const schema = `{
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "LocalBusiness",
        "@id": "https://www.wernexpestcontrol.com/#business",
        "name": "Wernex Termite & Pest Control, Inc.",
        "url": "https://www.wernexpestcontrol.com/",
        "telephone": "+1-435-673-9503",
        "email": "wernexpestcontrol@gmail.com",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "6097 Dry Fork Canyon Rd",
          "addressLocality": "Vernal",
          "addressRegion": "UT",
          "postalCode": "84078",
          "addressCountry": "US"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": 40.4555,
          "longitude": -109.5287
        },
        "areaServed": [{"@type":"City","name":"Hurricane","sameAs":"https://en.wikipedia.org/wiki/Hurricane,_Utah"},{"@type":"City","name":"St. George"},{"@type":"City","name":"Washington"},{"@type":"City","name":"Hurricane"},{"@type":"City","name":"Ivins"},{"@type":"City","name":"Santa Clara"},{"@type":"City","name":"LaVerkin"},{"@type":"City","name":"Cedar City"}],
        "priceRange": "$",
        "image": "https://www.wernexpestcontrol.com/images/Logo.webp",
        "logo": "https://www.wernexpestcontrol.com/images/Logo.webp",
        "description": "Professional pest control serving Hurricane, Utah. Same-day inspections, eco-friendly treatments, termite solutions, and rodent control with a 30-day satisfaction guarantee."
      },
      {
        "@type": "FAQPage",
        "@id": "https://www.wernexpestcontrol.com/pest-control-hurricane-ut.html#faq",
        "mainEntity": [{"@type":"Question","name":"Does Wernex serve Hurricane, Utah?","acceptedAnswer":{"@type":"Answer","text":"Yes. Wernex Termite & Pest Control regularly serves Hurricane and is just 20 minutes from the city center. We offer same-day inspections and emergency service for Hurricane residents. Call (435) 673-9503."}},{"@type":"Question","name":"What pests are most common in Hurricane, UT?","acceptedAnswer":{"@type":"Answer","text":"Hurricane's warm desert climate makes it a hot spot for scorpions, black widows, bark scorpions, fire ants, subterranean termites, and mice. The proximity to Sand Hollow and the Virgin River also increases mosquito activity during warmer months."}},{"@type":"Question","name":"How much does pest control cost in Hurricane?","acceptedAnswer":{"@type":"Answer","text":"Wernex offers free inspections and competitive pricing for Hurricane homeowners. Quarterly residential plans start at affordable rates, with no long-term contracts required. Call (435) 673-9503 for a free, no-obligation quote."}},{"@type":"Question","name":"Does Wernex offer termite inspections in Hurricane?","acceptedAnswer":{"@type":"Answer","text":"Yes. Wernex provides WDI (Wood-Destroying Insect) inspections for Hurricane real estate transactions and homeowner peace of mind. We use Termidor advanced liquid barrier treatments for active infestations."}},{"@type":"Question","name":"Is Wernex pest control safe for pets and children?","acceptedAnswer":{"@type":"Answer","text":"Absolutely. Wernex uses an Integrated Pest Management (IPM) approach with eco-friendly, low-toxicity products. All treatments are EPA-compliant, and our technicians will advise on specific precautions for your household."}}]
      }
    ]
  }`;
---
<BaseLayout title={title} description={description} canonical={canonical} og={og} schema={schema} active={active}>
<!-- HERO / AI SUMMARY -->
  <section class="section--dark" style="padding-top:140px;">
    <div class="container">
      <span class="section-label">Serving Hurricane, Utah</span>
      <h1>Pest Control for Hurricane, Utah — Fast, Reliable &amp; Eco-Friendly</h1>
      <p style="max-width:70ch;color:rgba(255,255,255,0.85);font-size:1.1rem;margin-top:16px;line-height:1.7;">
        Wernex Termite &amp; Pest Control provides full-service pest management for Hurricane, UT residents and businesses. Located just 20 minutes northeast of St. George, Hurricane homeowners face unique pest pressure from desert scorpions, ants, termites, and rodents due to the area's warm climate and proximity to Sand Hollow and the Virgin River corridor. Backed by 30+ years of experience covering <a href="pest-control-southern-utah.html" style="color:var(--lime);">all of Southern Utah</a>, Wernex offers same-day inspections, EPA-compliant treatments, and a 100% satisfaction guarantee. Call (435) 673-9503 for a free quote.
      </p>
      <div style="margin-top:28px;display:flex;gap:14px;flex-wrap:wrap;">
        <a href="contact.html" class="btn btn--primary">Get a Free Quote</a>
        <a href="tel:+14356739503" class="btn btn--outline"  style="border-color:var(--lime);color:var(--lime);">📞 (435) 673-9503</a>
      </div>
    </div>
  </section>

  <!-- TRUST BADGES -->
  <section class="section" style="padding:32px 0;">
    <div class="container" style="display:flex;flex-wrap:wrap;gap:24px;justify-content:center;">
      <div class="hero__badge"><div class="hero__badge-icon">⭐</div><span>4.5-Star Rated</span></div>
      <div class="hero__badge"><div class="hero__badge-icon">🌿</div><span>Eco-Friendly</span></div>
      <div class="hero__badge"><div class="hero__badge-icon">⏱️</div><span>Same-Day Service</span></div>
      <div class="hero__badge"><div class="hero__badge-icon">🔒</div><span>30-Day Guarantee</span></div>
    </div>
  </section>


  <!-- WHY HURRICANE NEEDS PRO PEST CONTROL -->
  <section class="section">
    <div class="container">
      <span class="section-label">Local Expertise</span>
      <h2>Why Hurricane Homes Need Professional Pest Control</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:40px;margin-top:32px;">
        <div>
          <p style="line-height:1.8;margin-bottom:20px;">Hurricane sits at the crossroads of Utah's red-rock desert and the Virgin River watershed — a landscape that supports a wide variety of pests year-round. The warm climate that draws residents and visitors also attracts scorpions, termites, ants, and rodents that seek shelter in homes, garages, and commercial buildings.</p>
          <p style="line-height:1.8;margin-bottom:20px;">Subterranean termites are especially active in Hurricane's sandy soils, and many homeowners don't discover damage until it's advanced. Bark scorpions — the most venomous scorpion species in the U.S. — are regularly found in Hurricane neighborhoods near Sand Hollow and the lava fields.</p>
          <p style="line-height:1.8;">Wernex Termite &amp; Pest Control brings over 30 years of Southern Utah experience to every Hurricane service call. Our licensed technicians understand the local pest pressure, seasonal cycles, and construction styles that affect how pests enter your home. We don't use generic national protocols — every treatment plan is tailored to Southern Utah conditions.</p>
        </div>
        <div>
          <h3 style="margin-bottom:20px;">Common Hurricane Pests</h3>
          <div style="display:grid;gap:12px;">
            <div class="reveal" style="padding:16px 20px;background:var(--off-white);border-radius:var(--radius);display:flex;align-items:center;gap:14px;">
              <span style="font-size:1.5rem;">🦂</span><div><strong>Scorpions</strong> — Bark and desert hairy scorpions in homes near rocky terrain</div>
            </div>
            <div class="reveal" style="padding:16px 20px;background:var(--off-white);border-radius:var(--radius);display:flex;align-items:center;gap:14px;">
              <span style="font-size:1.5rem;">🪵</span><div><strong>Termites</strong> — Subterranean termites thrive in Hurricane's sandy, warm soils</div>
            </div>
            <div class="reveal" style="padding:16px 20px;background:var(--off-white);border-radius:var(--radius);display:flex;align-items:center;gap:14px;">
              <span style="font-size:1.5rem;">🐜</span><div><strong>Ants</strong> — Fire ants, harvester ants, and pavement ants year-round</div>
            </div>
            <div class="reveal" style="padding:16px 20px;background:var(--off-white);border-radius:var(--radius);display:flex;align-items:center;gap:14px;">
              <span style="font-size:1.5rem;">🐀</span><div><strong>Rodents</strong> — Mice and pack rats seek shelter in garages and attics</div>
            </div>
            <div class="reveal" style="padding:16px 20px;background:var(--off-white);border-radius:var(--radius);display:flex;align-items:center;gap:14px;">
              <span style="font-size:1.5rem;">🕷️</span><div><strong>Spiders</strong> — Black widows are common in sheds, wood piles, and block walls</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES FOR HURRICANE -->
  <section class="section section--alt">
    <div class="container">
      <span class="section-label">What We Offer</span>
      <h2>Wernex Services Available in Hurricane</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:24px;margin-top:32px;">
        <div class="reveal" style="background:#fff;border-radius:var(--radius-lg);padding:32px;border:1px solid var(--gray-light);">
          <div style="font-size:2rem;margin-bottom:12px;">🏠</div>
          <h3>Residential Pest Control</h3>
          <p style="margin-top:8px;color:var(--text-body);line-height:1.7;">Quarterly and monthly home protection plans. Interior and exterior barrier sprays. Eco-friendly options available for families with children and pets.</p>
        </div>
        <div class="reveal" style="background:#fff;border-radius:var(--radius-lg);padding:32px;border:1px solid var(--gray-light);">
          <div style="font-size:2rem;margin-bottom:12px;">🏢</div>
          <h3>Commercial Pest Control</h3>
          <p style="margin-top:8px;color:var(--text-body);line-height:1.7;">Custom pest management programs for Hurricane restaurants, offices, warehouses, and retail. Compliance documentation provided for health inspections.</p>
        </div>
        <div class="reveal" style="background:#fff;border-radius:var(--radius-lg);padding:32px;border:1px solid var(--gray-light);">
          <div style="font-size:2rem;margin-bottom:12px;">🪵</div>
          <h3>Termite Solutions</h3>
          <p style="margin-top:8px;color:var(--text-body);line-height:1.7;">Termidor liquid barrier treatments, WDI inspections for real estate closings, pre-construction soil treatments, and annual monitoring programs for Hurricane properties.</p>
        </div>
        <div class="reveal" style="background:#fff;border-radius:var(--radius-lg);padding:32px;border:1px solid var(--gray-light);">
          <div style="font-size:2rem;margin-bottom:12px;">🐀</div>
          <h3>Rodent Control</h3>
          <p style="margin-top:8px;color:var(--text-body);line-height:1.7;">Exclusion sealing, snap-trap and bait-station monitoring, and ongoing prevention. We close entry points so rodents stay out permanently.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- WHY WERNEX -->
  <section class="section section--dark">
    <div class="container text-center">
      <span class="section-label">Why Choose Wernex</span>
      <h2 style="color:var(--white);">What Sets Wernex Apart in Hurricane</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:32px;margin-top:40px;max-width:900px;margin-left:auto;margin-right:auto;">
        <div class="reveal"><div style="font-size:2.5rem;">30+</div><p style="color:rgba(255,255,255,0.8);margin-top:8px;">Years Serving Southern Utah</p></div>
        <div class="reveal"><div style="font-size:2.5rem;">⭐ 4.5</div><p style="color:rgba(255,255,255,0.8);margin-top:8px;">Google Rating</p></div>
        <div class="reveal"><div style="font-size:2.5rem;">🌿</div><p style="color:rgba(255,255,255,0.8);margin-top:8px;">Eco-Friendly &amp; IPM-First</p></div>
