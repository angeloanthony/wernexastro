---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Same-Day Pest Control in St. George UT — Emergency Service Available | Wernex';
const description = 'Same-day pest control in St. George, Utah. Wernex offers emergency inspections and treatment for ants, spiders, scorpions, rodents, and more. Call (435) 673-9503 now.';
const canonical = 'https://www.wernexpestcontrol.com/same-day-pest-control-st-george.html';
const active = '';
const og = { "og:title": 'Same-Day Pest Control in St. George UT — Emergency Service Available | Wernex', "og:description": 'Same-day pest control in St. George, Utah. Wernex offers emergency inspections and treatment for ants, spiders, scorpions, rodents, and more. Call (435) 673-9503 now.', "og:type": 'website', "og:url": 'https://www.wernexpestcontrol.com/same-day-pest-control-st-george.html', "og:locale": 'en_US', "og:site_name": 'Wernex Termite & Pest Control' };
const schema = `{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "@id": "https://www.wernexpestcontrol.com/#business",
      "name": "Wernex Termite & Pest Control, Inc.",
      "url": "https://www.wernexpestcontrol.com/",
      "telephone": "+1-435-673-9503",
      "email": "wernexpestcontrol@gmail.com",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "6097 Dry Fork Canyon Rd",
        "addressLocality": "Vernal",
        "addressRegion": "UT",
        "postalCode": "84078",
        "addressCountry": "US"
      },
      "priceRange": "$"
    },
    {
      "@type": "WebPage",
      "@id": "https://www.wernexpestcontrol.com/same-day-pest-control-st-george.html#webpage",
      "url": "https://www.wernexpestcontrol.com/same-day-pest-control-st-george.html",
      "name": "Same-Day Pest Control in St. George UT \\u2014 Emergency Service Available | Wernex",
      "isPartOf": {
        "@id": "https://www.wernexpestcontrol.com/#website"
      },
      "about": {
        "@id": "https://www.wernexpestcontrol.com/#business"
      },
      "breadcrumb": {
        "@id": "https://www.wernexpestcontrol.com/same-day-pest-control-st-george.html#breadcrumb"
      }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.wernexpestcontrol.com/same-day-pest-control-st-george.html#breadcrumb",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://www.wernexpestcontrol.com/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Same-Day Pest Control St. George",
          "item": "https://www.wernexpestcontrol.com/same-day-pest-control-st-george.html"
        }
      ]
    },
    {
      "@type": "FAQPage",
      "@id": "https://www.wernexpestcontrol.com/same-day-pest-control-st-george.html#faq",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Can I really get pest control service today in St. George?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. Wernex offers same-day inspections and treatment throughout St. George, Washington, Hurricane, Ivins, Santa Clara, LaVerkin, and surrounding communities. Call (435) 673-9503 and we'll dispatch a licensed technician to your property as quickly as possible."
          }
        },
        {
          "@type": "Question",
          "name": "What pest emergencies qualify for same-day service?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "All pest issues qualify. The most common same-day requests include scorpion sightings, wasp nests near living areas, rodent activity in kitchens or attics, bed bug discovery, and large ant invasions. Whatever the pest, we can respond the same day."
          }
        },
        {
          "@type": "Question",
          "name": "Is same-day service more expensive?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No. Wernex does not charge extra for same-day scheduling. You pay the same rate whether you book a week in advance or call this morning. No rush fees, no emergency surcharges."
          }
        },
        {
          "@type": "Question",
          "name": "What hours is same-day service available?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "We're available Monday through Friday 7am\\u20137pm and Saturday 8am\\u20135pm. Call (435) 673-9503 during business hours for same-day dispatch."
          }
        }
      ]
    }
  ]
}`;
---
<BaseLayout title={title} description={description} canonical={canonical} og={og} schema={schema} active={active}>
<!-- ═══ HERO ═══ -->
  <section class="hero" style="min-height:auto;padding:160px 0 80px;">
    <div class="hero__bg-gradient"></div>
    <div class="container">
      <div class="hero__content reveal" style="--delay:0;max-width:800px;">
        <div class="hero__pre-label">
          <span class="hero__dot"></span>
          Licensed &amp; Insured • 30+ Years
        </div>
        <h1>Same-Day Pest Control<br><span>St. George &amp; Southern Utah</span></h1>

        <!-- ═══ SEO: AI SUMMARY BLOCK ═══ -->
        <p>Wernex Termite &amp; Pest Control offers same-day pest control service in St. George and throughout Southern Utah. When you have a pest emergency — scorpion in your child's room, wasp nest over your front door, mice in your kitchen — waiting days for an appointment isn't an option. Wernex dispatches licensed technicians the same day you call, with full treatment capability on every truck. Call (435) 673-9503 for immediate scheduling.</p>

        <div class="hero__buttons" style="margin-top:28px;">
          <a href="contact.html" class="btn btn--primary">Get a Free Quote →</a>
          <a href="tel:+14356739503" class="btn btn--white">📞 (435) 673-9503</a>
        </div>
        <div class="hero__badges" style="margin-top:24px;">
          <div class="hero__badge"><div class="hero__badge-icon">✓</div><span>Licensed &amp; Insured</span></div>
          <div class="hero__badge"><div class="hero__badge-icon">🌿</div><span>Eco-Friendly</span></div>
          <div class="hero__badge"><div class="hero__badge-icon">⏱️</div><span>Same-Day Service</span></div>
          <div class="hero__badge"><div class="hero__badge-icon">🔒</div><span>Satisfaction Guaranteed</span></div>
        </div>
      </div>
    </div>
  </section>

    <section class="section">
      <div class="container">
        <div class="text-center reveal">
          <span class="section-label">When You Can't Wait</span>
          <h2>Pest Emergencies That Need Immediate Response</h2>
          <p class="mx-auto" style="margin-top:12px;color:var(--gray);">Some pest situations are urgent. Waiting days for an appointment means more risk to your family, more damage to your property, and more stress.</p>
        </div>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:24px;margin-top:48px;">
          <div class="card reveal"><div class="card__body"><h3>🦂 Scorpion in the House</h3><p style="color:var(--gray);">Bark scorpion stings are painful and can be dangerous — especially for children and elderly family members. If you find one scorpion, there are almost certainly more. Same-day UV detection sweeps locate the population.</p></div></div>
          <div class="card reveal"><div class="card__body"><h3>🐝 Aggressive Wasp Nest</h3><p style="color:var(--gray);">A wasp nest over your front door or near your patio makes your outdoor space unusable. Yellow jacket ground nests are especially dangerous for children and pets playing in the yard.</p></div></div>
          <div class="card reveal"><div class="card__body"><h3>🐀 Rodent Sounds at Night</h3><p style="color:var(--gray);">Scratching in walls or attic means rodents are already nesting. They contaminate food, chew electrical wiring (fire risk), and can spread disease. Every day of delay means more damage.</p></div></div>
          <div class="card reveal"><div class="card__body"><h3>🛏️ Bed Bug Discovery</h3><p style="color:var(--gray);">Finding bed bugs in your mattress or furniture is distressing. They spread rapidly — a few bugs become hundreds within weeks. Early treatment is critical for containment.</p></div></div>
        </div>
      </div>
    </section>

    <section class="section--dark section">
      <div class="container">
        <div class="stats-bar">
          <div class="stat reveal"><div class="stat__number">Same Day</div><div class="stat__label">Dispatch Available</div></div>
          <div class="stat reveal"><div class="stat__number">$0</div><div class="stat__label">Rush Fee — Ever</div></div>
          <div class="stat reveal"><div class="stat__number">100%</div><div class="stat__label">Satisfaction Guarantee</div></div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="text-center reveal"><span class="section-label">Explore More</span><h2>Related Pages</h2></div>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:16px;margin-top:32px;">
          <a href="pest-control-southern-utah.html" class="btn btn--outline" style="text-align:center;">🛡️ All Southern Utah Services</a>
          <a href="affordable-pest-control-st-george.html" class="btn btn--outline" style="text-align:center;">💰 Affordable Plans</a>
          <a href="scorpion-control-st-george.html" class="btn btn--outline" style="text-align:center;">🦂 Scorpion Control</a>
          <a href="contact.html" class="btn btn--outline" style="text-align:center;">📞 Schedule Now</a>
        </div>
      </div>
    </section>

    <!-- ═══ FAQ SECTION ═══ -->
    <section class="section--alt section">
      <div class="container">
        <div class="text-center reveal">
          <span class="section-label">Common Questions</span>
          <h2>Frequently Asked Questions</h2>
        </div>
        <div style="max-width:800px;margin:40px auto 0;">

        <details class="reveal" style="background:var(--off-white);border-radius:var(--radius);padding:20px 24px;margin-bottom:12px;cursor:pointer;">
          <summary style="font-family:var(--font-display);font-weight:700;font-size:1.05rem;color:var(--text-dark);">Can I really get pest control service today in St. George?</summary>
          <p style="margin-top:12px;color:var(--text-body);max-width:65ch;">Yes. Wernex offers same-day inspections and treatment throughout St. George, Washington, Hurricane, Ivins, Santa Clara, LaVerkin, and surrounding communities. Call (435) 673-9503 and we'll dispatch a licensed technician to your property as quickly as possible.</p>
        </details>
        <details class="reveal" style="background:var(--off-white);border-radius:var(--radius);padding:20px 24px;margin-bottom:12px;cursor:pointer;">
          <summary style="font-family:var(--font-display);font-weight:700;font-size:1.05rem;color:var(--text-dark);">What pest emergencies qualify for same-day service?</summary>
          <p style="margin-top:12px;color:var(--text-body);max-width:65ch;">All pest issues qualify. The most common same-day requests include scorpion sightings, wasp nests near living areas, rodent activity in kitchens or attics, bed bug discovery, and large ant invasions. Whatever the pest, we can respond the same day.</p>
        </details>
        <details class="reveal" style="background:var(--off-white);border-radius:var(--radius);padding:20px 24px;margin-bottom:12px;cursor:pointer;">
          <summary style="font-family:var(--font-display);font-weight:700;font-size:1.05rem;color:var(--text-dark);">Is same-day service more expensive?</summary>
          <p style="margin-top:12px;color:var(--text-body);max-width:65ch;">No. Wernex does not charge extra for same-day scheduling. You pay the same rate whether you book a week in advance or call this morning. No rush fees, no emergency surcharges.</p>
        </details>
        <details class="reveal" style="background:var(--off-white);border-radius:var(--radius);padding:20px 24px;margin-bottom:12px;cursor:pointer;">
          <summary style="font-family:var(--font-display);font-weight:700;font-size:1.05rem;color:var(--text-dark);">What hours is same-day service available?</summary>
          <p style="margin-top:12px;color:var(--text-body);max-width:65ch;">We're available Monday through Friday 7am–7pm and Saturday 8am–5pm. Call (435) 673-9503 during business hours for same-day dispatch.</p>
        </details>
        </div>
      </div>
    </section>

    <!-- ═══ CTA SECTION ═══ -->
    <section class="section--dark section">
      <div class="container text-center">
        <h2>Ready to Get Started?</h2>
        <p class="mx-auto" style="margin-top:12px;color:rgba(255,255,255,0.8);">Call Wernex today for a free inspection and quote. Same-day service available throughout Southern Utah.</p>
        <div style="margin-top:28px;display:flex;gap:16px;justify-content:center;flex-wrap:wrap;">
          <a href="tel:+14356739503" class="btn btn--white">📞 (435) 673-9503</a>
          <a href="contact.html" class="btn btn--primary">Schedule Online →</a>
        </div>
      </div>
    </section>

  <!-- ═══ FOOTER ═══ -->
</BaseLayout>
