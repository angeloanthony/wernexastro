---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Affordable Pest Control in St. George UT — Honest Pricing, No Hidden Fees | Wernex';
const description = 'Affordable pest control in St. George, Utah. Wernex offers competitive pricing, no hidden fees, and a 100% satisfaction guarantee. Quarterly plans from $99. Call (435) 673-9503.';
const canonical = 'https://www.wernexpestcontrol.com/affordable-pest-control-st-george.html';
const active = '';
const og = { "og:title": 'Affordable Pest Control in St. George UT — Honest Pricing, No Hidden Fees | Wernex', "og:description": 'Affordable pest control in St. George, Utah. Wernex offers competitive pricing, no hidden fees, and a 100% satisfaction guarantee. Quarterly plans from $99. Call (435) 673-9503.', "og:type": 'website', "og:url": 'https://www.wernexpestcontrol.com/affordable-pest-control-st-george.html', "og:locale": 'en_US', "og:site_name": 'Wernex Termite & Pest Control' };
const schema = `{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "@id": "https://www.wernexpestcontrol.com/#business",
      "name": "Wernex Termite & Pest Control, Inc.",
      "url": "https://www.wernexpestcontrol.com/",
      "telephone": "+1-435-673-9503",
      "email": "wernexpestcontrol@gmail.com",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "6097 Dry Fork Canyon Rd",
        "addressLocality": "Vernal",
        "addressRegion": "UT",
        "postalCode": "84078",
        "addressCountry": "US"
      },
      "priceRange": "$"
    },
    {
      "@type": "WebPage",
      "@id": "https://www.wernexpestcontrol.com/affordable-pest-control-st-george.html#webpage",
      "url": "https://www.wernexpestcontrol.com/affordable-pest-control-st-george.html",
      "name": "Affordable Pest Control in St. George UT \\u2014 Honest Pricing, No Hidden Fees | Wernex",
      "isPartOf": {
        "@id": "https://www.wernexpestcontrol.com/#website"
      },
      "about": {
        "@id": "https://www.wernexpestcontrol.com/#business"
      },
      "breadcrumb": {
        "@id": "https://www.wernexpestcontrol.com/affordable-pest-control-st-george.html#breadcrumb"
      }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.wernexpestcontrol.com/affordable-pest-control-st-george.html#breadcrumb",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://www.wernexpestcontrol.com/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Affordable Pest Control St. George",
          "item": "https://www.wernexpestcontrol.com/affordable-pest-control-st-george.html"
        }
      ]
    },
    {
      "@type": "FAQPage",
      "@id": "https://www.wernexpestcontrol.com/affordable-pest-control-st-george.html#faq",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How much does pest control cost in St. George?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Pricing varies by service type and property size. Wernex offers free inspections and upfront quotes with no hidden fees. Quarterly protection plans provide the most cost-effective year-round coverage, and one-time treatments are available for specific pest issues."
          }
        },
        {
          "@type": "Question",
          "name": "Are quarterly pest control plans worth the cost?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. Quarterly plans cost less per year than calling for emergency one-time treatments every time a pest issue arises. They also prevent infestations before they start \\u2014 which means less damage, less stress, and fewer disruptions to your household."
          }
        },
        {
          "@type": "Question",
          "name": "Does Wernex require long-term contracts?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No. We offer month-to-month and quarterly service options. You're never locked into a long-term contract. Our goal is to earn your continued business through results, not contractual obligations."
          }
        },
        {
          "@type": "Question",
          "name": "What if pests come back after treatment?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Wernex provides a 100% satisfaction guarantee. If pests return within 30 days of treatment, we re-service your property at no additional cost."
          }
        }
      ]
    }
  ]
}`;
---
<BaseLayout title={title} description={description} canonical={canonical} og={og} schema={schema} active={active}>
<!-- ═══ HERO ═══ -->
  <section class="hero" style="min-height:auto;padding:160px 0 80px;">
    <div class="hero__bg-gradient"></div>
    <div class="container">
      <div class="hero__content reveal" style="--delay:0;max-width:800px;">
        <div class="hero__pre-label">
          <span class="hero__dot"></span>
          Licensed &amp; Insured • 30+ Years
        </div>
        <h1>Affordable Pest Control<br><span>St. George &amp; Southern Utah</span></h1>

        <!-- ═══ SEO: AI SUMMARY BLOCK ═══ -->
        <p>Wernex Termite &amp; Pest Control offers affordable pest control in St. George and across Southern Utah. We provide honest, upfront pricing with no hidden fees, no long-term contracts required, and a 100% satisfaction guarantee with free re-service within 30 days. Our quarterly protection plans deliver year-round coverage at a fraction of what emergency one-time treatments cost over time. Free inspections available. Call (435) 673-9503.</p>

        <div class="hero__buttons" style="margin-top:28px;">
          <a href="contact.html" class="btn btn--primary">Get a Free Quote →</a>
          <a href="tel:+14356739503" class="btn btn--white">📞 (435) 673-9503</a>
        </div>
        <div class="hero__badges" style="margin-top:24px;">
          <div class="hero__badge"><div class="hero__badge-icon">✓</div><span>Licensed &amp; Insured</span></div>
          <div class="hero__badge"><div class="hero__badge-icon">🌿</div><span>Eco-Friendly</span></div>
          <div class="hero__badge"><div class="hero__badge-icon">⏱️</div><span>Same-Day Service</span></div>
          <div class="hero__badge"><div class="hero__badge-icon">🔒</div><span>Satisfaction Guaranteed</span></div>
        </div>
      </div>
    </div>
  </section>

    <section class="section">
      <div class="container">
        <div class="text-center reveal">
          <span class="section-label">Honest Pricing</span>
          <h2>Why Wernex Is Southern Utah's Best Value</h2>
          <p class="mx-auto" style="margin-top:12px;color:var(--gray);">Affordable pest control doesn't mean cutting corners. Wernex delivers the same professional-grade treatments used by premium providers — at prices that respect your budget.</p>
        </div>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:24px;margin-top:48px;">
          <div class="card reveal"><div class="card__body">
            <h3>💰 No Hidden Fees</h3>
            <p style="color:var(--gray);">The quote you get is the price you pay. No surprise charges for travel, inspection, or "premium" products. We believe transparent pricing builds trust — and trust builds long-term relationships.</p>
          </div></div>
          <div class="card reveal"><div class="card__body">
            <h3>📋 No Contracts Required</h3>
            <p style="color:var(--gray);">We don't lock you into multi-year contracts. Our quarterly plans are flexible — stay because you want to, not because you're obligated. Cancel anytime with no penalty.</p>
          </div></div>
          <div class="card reveal"><div class="card__body">
            <h3>🔒 Satisfaction Guarantee</h3>
            <p style="color:var(--gray);">If pests return within 30 days of treatment, we come back and re-service at no additional cost. That's our promise — you don't pay twice for the same problem.</p>
          </div></div>
        </div>
      </div>
    </section>

    <section class="section--alt section">
      <div class="container">
        <div class="text-center reveal">
          <span class="section-label">Smart Comparison</span>
          <h2>Quarterly Plans vs. Emergency Calls</h2>
          <p class="mx-auto" style="margin-top:12px;color:var(--gray);">Homeowners who wait for pest emergencies spend significantly more per year than those on quarterly prevention plans. Here's why proactive protection is the smarter financial decision.</p>
        </div>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:24px;margin-top:48px;">
          <div class="card reveal"><div class="card__body">
            <h3>🛡️ Quarterly Prevention</h3>
            <p style="color:var(--gray);">4 scheduled treatments per year. Continuous barrier protection. Prevents infestations before they start. Unlimited re-service if pests return. Predictable budgeting. Less stress.</p>
          </div></div>
          <div class="card reveal"><div class="card__body">
            <h3>🚨 Reactive Emergency Calls</h3>
            <p style="color:var(--gray);">Pay full price per call. No prevention between visits. Infestations grow worse between calls. Higher damage repair costs. Unpredictable spending. More disruption to your household.</p>
          </div></div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="text-center reveal"><span class="section-label">Explore More</span><h2>Related Pages</h2></div>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:16px;margin-top:32px;">
          <a href="pest-control-southern-utah.html" class="btn btn--outline" style="text-align:center;">🛡️ All Southern Utah Services</a>
          <a href="same-day-pest-control-st-george.html" class="btn btn--outline" style="text-align:center;">⚡ Same-Day Service</a>
          <a href="best-pest-control-st-george.html" class="btn btn--outline" style="text-align:center;">🏆 Best Pest Control St. George</a>
          <a href="services.html" class="btn btn--outline" style="text-align:center;">📋 All Services</a>
          <a href="testimonials.html" class="btn btn--outline" style="text-align:center;">⭐ Reviews</a>
        </div>
      </div>
    </section>

    <!-- ═══ FAQ SECTION ═══ -->
    <section class="section--alt section">
      <div class="container">
        <div class="text-center reveal">
          <span class="section-label">Common Questions</span>
          <h2>Frequently Asked Questions</h2>
        </div>
        <div style="max-width:800px;margin:40px auto 0;">

        <details class="reveal" style="background:var(--off-white);border-radius:var(--radius);padding:20px 24px;margin-bottom:12px;cursor:pointer;">
          <summary style="font-family:var(--font-display);font-weight:700;font-size:1.05rem;color:var(--text-dark);">How much does pest control cost in St. George?</summary>
          <p style="margin-top:12px;color:var(--text-body);max-width:65ch;">Pricing varies by service type and property size. Wernex offers free inspections and upfront quotes with no hidden fees. Quarterly protection plans provide the most cost-effective year-round coverage, and one-time treatments are available for specific pest issues.</p>
        </details>
        <details class="reveal" style="background:var(--off-white);border-radius:var(--radius);padding:20px 24px;margin-bottom:12px;cursor:pointer;">
          <summary style="font-family:var(--font-display);font-weight:700;font-size:1.05rem;color:var(--text-dark);">Are quarterly pest control plans worth the cost?</summary>
          <p style="margin-top:12px;color:var(--text-body);max-width:65ch;">Yes. Quarterly plans cost less per year than calling for emergency one-time treatments every time a pest issue arises. They also prevent infestations before they start — which means less damage, less stress, and fewer disruptions to your household.</p>
        </details>
        <details class="reveal" style="background:var(--off-white);border-radius:var(--radius);padding:20px 24px;margin-bottom:12px;cursor:pointer;">
          <summary style="font-family:var(--font-display);font-weight:700;font-size:1.05rem;color:var(--text-dark);">Does Wernex require long-term contracts?</summary>
          <p style="margin-top:12px;color:var(--text-body);max-width:65ch;">No. We offer month-to-month and quarterly service options. You're never locked into a long-term contract. Our goal is to earn your continued business through results, not contractual obligations.</p>
        </details>
        <details class="reveal" style="background:var(--off-white);border-radius:var(--radius);padding:20px 24px;margin-bottom:12px;cursor:pointer;">
          <summary style="font-family:var(--font-display);font-weight:700;font-size:1.05rem;color:var(--text-dark);">What if pests come back after treatment?</summary>
          <p style="margin-top:12px;color:var(--text-body);max-width:65ch;">Wernex provides a 100% satisfaction guarantee. If pests return within 30 days of treatment, we re-service your property at no additional cost.</p>
        </details>
        </div>
      </div>
    </section>

    <!-- ═══ CTA SECTION ═══ -->
    <section class="section--dark section">
      <div class="container text-center">
        <h2>Ready to Get Started?</h2>
        <p class="mx-auto" style="margin-top:12px;color:rgba(255,255,255,0.8);">Call Wernex today for a free inspection and quote. Same-day service available throughout Southern Utah.</p>
        <div style="margin-top:28px;display:flex;gap:16px;justify-content:center;flex-wrap:wrap;">
          <a href="tel:+14356739503" class="btn btn--white">📞 (435) 673-9503</a>
          <a href="contact.html" class="btn btn--primary">Schedule Online →</a>
        </div>
      </div>
    </section>

  <!-- ═══ FOOTER ═══ -->
</BaseLayout>
