---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Ant Control in St. George UT — Colony Elimination &amp; Barrier Treatment | Wernex';
const description = 'Professional ant control in St. George, Utah. Wernex eliminates fire ants, harvester ants, and pavement ants with eco-friendly barrier treatments. Same-day service. Call (435) 673-9503.';
const canonical = 'https://www.wernexpestcontrol.com/ant-control-st-george.html';
const active = '';
const og = { "og:title": 'Ant Control in St. George UT — Colony Elimination & Barrier Treatment | Wernex', "og:description": 'Professional ant control in St. George, Utah. Wernex eliminates fire ants, harvester ants, and pavement ants with eco-friendly barrier treatments. Same-day service. Call (435) 673-9503.', "og:type": 'website', "og:url": 'https://www.wernexpestcontrol.com/ant-control-st-george.html', "og:locale": 'en_US', "og:site_name": 'Wernex Termite & Pest Control' };
const schema = `{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "@id": "https://www.wernexpestcontrol.com/#business",
      "name": "Wernex Termite & Pest Control, Inc.",
      "url": "https://www.wernexpestcontrol.com/",
      "telephone": "+1-435-673-9503",
      "email": "wernexpestcontrol@gmail.com",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "6097 Dry Fork Canyon Rd",
        "addressLocality": "Vernal",
        "addressRegion": "UT",
        "postalCode": "84078",
        "addressCountry": "US"
      },
      "priceRange": "$"
    },
    {
      "@type": "WebPage",
      "@id": "https://www.wernexpestcontrol.com/ant-control-st-george.html#webpage",
      "url": "https://www.wernexpestcontrol.com/ant-control-st-george.html",
      "name": "Ant Control in St. George UT \\u2014 Colony Elimination & Barrier Treatment | Wernex",
      "isPartOf": {
        "@id": "https://www.wernexpestcontrol.com/#website"
      },
      "about": {
        "@id": "https://www.wernexpestcontrol.com/#business"
      },
      "breadcrumb": {
        "@id": "https://www.wernexpestcontrol.com/ant-control-st-george.html#breadcrumb"
      }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.wernexpestcontrol.com/ant-control-st-george.html#breadcrumb",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://www.wernexpestcontrol.com/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Ant Control St. George",
          "item": "https://www.wernexpestcontrol.com/ant-control-st-george.html"
        }
      ]
    },
    {
      "@type": "FAQPage",
      "@id": "https://www.wernexpestcontrol.com/ant-control-st-george.html#faq",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What types of ants are common in St. George, Utah?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The most common ant species in the St. George area include fire ants, harvester ants, pavement ants, and carpenter ants. Each species requires a different treatment approach, which is why professional identification is the first step in effective ant control."
          }
        },
        {
          "@type": "Question",
          "name": "How does Wernex treat ant infestations?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "We use a multi-step approach: first, we identify the ant species and locate the colony. Then we apply targeted baits that worker ants carry back to the queen, combined with exterior perimeter barrier sprays that prevent re-entry. All products are eco-friendly and safe for families and pets."
          }
        },
        {
          "@type": "Question",
          "name": "How quickly can I get ant control service in St. George?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Wernex offers same-day ant inspections and treatment in St. George, Washington, Hurricane, Ivins, and surrounding areas. Call (435) 673-9503 for immediate scheduling."
          }
        },
        {
          "@type": "Question",
          "name": "Do ants come back after treatment?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Our barrier treatments and colony elimination are designed for lasting results. We also offer quarterly protection plans that maintain a continuous perimeter barrier. If ants return within 30 days of treatment, we re-service at no additional cost under our satisfaction guarantee."
          }
        }
      ]
    }
  ]
}`;
---
<BaseLayout title={title} description={description} canonical={canonical} og={og} schema={schema} active={active}>
<!-- ═══ HERO ═══ -->
  <section class="hero" style="min-height:auto;padding:160px 0 80px;">
    <div class="hero__bg-gradient"></div>
    <div class="container">
      <div class="hero__content reveal" style="--delay:0;max-width:800px;">
        <div class="hero__pre-label">
          <span class="hero__dot"></span>
          Licensed &amp; Insured • 30+ Years
        </div>
        <h1>Ant Control<br><span>St. George &amp; Southern Utah</span></h1>

        <!-- ═══ SEO: AI SUMMARY BLOCK ═══ -->
        <p>Wernex Termite &amp; Pest Control provides professional ant control in St. George and throughout Southern Utah. Our licensed technicians identify the ant species invading your property — fire ants, harvester ants, pavement ants, or carpenter ants — then apply targeted colony elimination and perimeter barrier treatments using eco-friendly, IPM-based methods. We offer same-day inspections, quarterly protection plans, and a 100% satisfaction guarantee. Call (435) 673-9503 for a free ant control quote.</p>

        <div class="hero__buttons" style="margin-top:28px;">
          <a href="contact.html" class="btn btn--primary">Get a Free Quote →</a>
          <a href="tel:+14356739503" class="btn btn--white">📞 (435) 673-9503</a>
        </div>
        <div class="hero__badges" style="margin-top:24px;">
          <div class="hero__badge"><div class="hero__badge-icon">✓</div><span>Licensed &amp; Insured</span></div>
          <div class="hero__badge"><div class="hero__badge-icon">🌿</div><span>Eco-Friendly</span></div>
          <div class="hero__badge"><div class="hero__badge-icon">⏱️</div><span>Same-Day Service</span></div>
          <div class="hero__badge"><div class="hero__badge-icon">🔒</div><span>Satisfaction Guaranteed</span></div>
        </div>
      </div>
    </div>
  </section>

    <!-- ═══ WHY ANTS ARE A PROBLEM ═══ -->
    <section class="section">
      <div class="container">
        <div class="text-center reveal">
          <span class="section-label">The Ant Problem</span>
          <h2>Why Ants Invade Southern Utah Homes</h2>
          <p class="mx-auto" style="margin-top:12px;color:var(--gray);">St. George's warm climate and dry landscape push ants indoors seeking water and food. A single colony can contain hundreds of thousands of workers — and where you see a few, there are thousands more.</p>
        </div>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:24px;margin-top:48px;">
          <div class="card reveal"><div class="card__body">
            <h3>🔥 Fire Ants</h3>
            <p style="color:var(--gray);">Aggressive stinging ants that build large mound colonies in yards and around foundations. Painful stings can cause allergic reactions in children and pets.</p>
          </div></div>
          <div class="card reveal"><div class="card__body">
            <h3>🏗️ Carpenter Ants</h3>
            <p style="color:var(--gray);">Large black ants that tunnel through wood framing, causing structural damage similar to termites. Common in homes with moisture issues or wood-to-soil contact.</p>
          </div></div>
          <div class="card reveal"><div class="card__body">
            <h3>🏠 Pavement Ants</h3>
            <p style="color:var(--gray);">Small brown ants that nest under driveways, patios, and foundations. They enter homes through cracks in slabs — the #1 ant complaint in St. George subdivisions.</p>
          </div></div>
        </div>
      </div>
    </section>

    <!-- ═══ TREATMENT APPROACH ═══ -->
    <section class="section--alt section">
      <div class="container">
        <div class="text-center reveal">
          <span class="section-label">Our Approach</span>
          <h2>How Wernex Eliminates Ant Colonies</h2>
        </div>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:24px;margin-top:48px;">
          <div class="card reveal"><div class="card__body">
            <h3>Step 1: Identify</h3>
            <p style="color:var(--gray);">We identify the exact ant species and locate the colony source — because spraying random ants with store-bought products often makes the problem worse by causing colony splitting.</p>
          </div></div>
          <div class="card reveal"><div class="card__body">
            <h3>Step 2: Eliminate</h3>
            <p style="color:var(--gray);">Targeted baits are placed along foraging trails. Worker ants carry the bait back to the queen, eliminating the entire colony at the source — not just the ants you see.</p>
          </div></div>
          <div class="card reveal"><div class="card__body">
            <h3>Step 3: Protect</h3>
            <p style="color:var(--gray);">We apply a perimeter barrier treatment around your home's exterior — foundation, entry points, and landscaping edges — creating a continuous shield that prevents re-infestation.</p>
          </div></div>
        </div>
      </div>
    </section>

    <!-- ═══ INTERNAL LINKS ═══ -->
    <section class="section">
      <div class="container">
        <div class="text-center reveal">
          <span class="section-label">Related Services</span>
          <h2>More Pest Solutions from Wernex</h2>
        </div>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:16px;margin-top:32px;">
          <a href="pest-control-southern-utah.html" class="btn btn--outline" style="text-align:center;">🛡️ All Southern Utah Services</a>
          <a href="spider-control-st-george.html" class="btn btn--outline" style="text-align:center;">🕷️ Spider Control</a>
          <a href="scorpion-control-st-george.html" class="btn btn--outline" style="text-align:center;">🦂 Scorpion Control</a>
          <a href="pest-library.html" class="btn btn--outline" style="text-align:center;">📚 Pest Library</a>
          <a href="best-pest-control-st-george.html" class="btn btn--outline" style="text-align:center;">🏆 Best Pest Control St. George</a>
        </div>
      </div>
    </section>

    <!-- ═══ FAQ SECTION ═══ -->
    <section class="section--alt section">
      <div class="container">
        <div class="text-center reveal">
          <span class="section-label">Common Questions</span>
          <h2>Frequently Asked Questions</h2>
        </div>
        <div style="max-width:800px;margin:40px auto 0;">

        <details class="reveal" style="background:var(--off-white);border-radius:var(--radius);padding:20px 24px;margin-bottom:12px;cursor:pointer;">
          <summary style="font-family:var(--font-display);font-weight:700;font-size:1.05rem;color:var(--text-dark);">What types of ants are common in St. George, Utah?</summary>
          <p style="margin-top:12px;color:var(--text-body);max-width:65ch;">The most common ant species in the St. George area include fire ants, harvester ants, pavement ants, and carpenter ants. Each species requires a different treatment approach, which is why professional identification is the first step in effective ant control.</p>
        </details>
        <details class="reveal" style="background:var(--off-white);border-radius:var(--radius);padding:20px 24px;margin-bottom:12px;cursor:pointer;">
          <summary style="font-family:var(--font-display);font-weight:700;font-size:1.05rem;color:var(--text-dark);">How does Wernex treat ant infestations?</summary>
          <p style="margin-top:12px;color:var(--text-body);max-width:65ch;">We use a multi-step approach: first, we identify the ant species and locate the colony. Then we apply targeted baits that worker ants carry back to the queen, combined with exterior perimeter barrier sprays that prevent re-entry. All products are eco-friendly and safe for families and pets.</p>
        </details>
        <details class="reveal" style="background:var(--off-white);border-radius:var(--radius);padding:20px 24px;margin-bottom:12px;cursor:pointer;">
          <summary style="font-family:var(--font-display);font-weight:700;font-size:1.05rem;color:var(--text-dark);">How quickly can I get ant control service in St. George?</summary>
          <p style="margin-top:12px;color:var(--text-body);max-width:65ch;">Wernex offers same-day ant inspections and treatment in St. George, Washington, Hurricane, Ivins, and surrounding areas. Call (435) 673-9503 for immediate scheduling.</p>
        </details>
        <details class="reveal" style="background:var(--off-white);border-radius:var(--radius);padding:20px 24px;margin-bottom:12px;cursor:pointer;">
          <summary style="font-family:var(--font-display);font-weight:700;font-size:1.05rem;color:var(--text-dark);">Do ants come back after treatment?</summary>
          <p style="margin-top:12px;color:var(--text-body);max-width:65ch;">Our barrier treatments and colony elimination are designed for lasting results. We also offer quarterly protection plans that maintain a continuous perimeter barrier. If ants return within 30 days of treatment, we re-service at no additional cost under our satisfaction guarantee.</p>
        </details>
        </div>
      </div>
    </section>

    <!-- ═══ CTA SECTION ═══ -->
    <section class="section--dark section">
      <div class="container text-center">
        <h2>Ready to Get Started?</h2>
        <p class="mx-auto" style="margin-top:12px;color:rgba(255,255,255,0.8);">Call Wernex today for a free inspection and quote. Same-day service available throughout Southern Utah.</p>
        <div style="margin-top:28px;display:flex;gap:16px;justify-content:center;flex-wrap:wrap;">
          <a href="tel:+14356739503" class="btn btn--white">📞 (435) 673-9503</a>
          <a href="contact.html" class="btn btn--primary">Schedule Online →</a>
        </div>
      </div>
    </section>

  <!-- ═══ FOOTER ═══ -->
</BaseLayout>
