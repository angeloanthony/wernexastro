---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Pest Control Services in St. George UT — Residential, Commercial, Termite &amp; Rodent | Wernex';
const description = 'Full-service pest control in St. George & Southern Utah: residential plans, commercial programs, termite treatments, and rodent exclusion. 30+ years experience. Free inspections — call (435) 673-9503.';
const canonical = 'https://www.wernexpestcontrol.com/services.html';
const active = 'services.html';
const og = { "og:title": 'Pest Control Services — Residential, Commercial, Termite & Rodent | Wernex', "og:description": 'Full-service pest control in St. George & Southern Utah. Residential, commercial, termite, and rodent solutions. Free inspections.', "og:type": 'website', "og:url": 'https://www.wernexpestcontrol.com/services.html', "og:locale": 'en_US', "og:site_name": 'Wernex Termite & Pest Control' };
const schema = `{
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Service",
        "@id": "https://www.wernexpestcontrol.com/services.html#residential",
        "name": "Residential Pest Control",
        "description": "Year-round home pest protection plans with quarterly treatments, emergency callbacks, and seasonal adjustments for Southern Utah pest pressure.",
        "provider": { "@id": "https://www.wernexpestcontrol.com/#business" },
        "areaServed": { "@type": "State", "name": "Utah" },
        "serviceType": "Residential Pest Control",
        "url": "https://www.wernexpestcontrol.com/services.html#residential"
      },
      {
        "@type": "Service",
        "@id": "https://www.wernexpestcontrol.com/services.html#commercial",
        "name": "Commercial Pest Management",
        "description": "Custom pest control programs for restaurants, hotels, offices, warehouses, and healthcare facilities in Southern Utah. Health code compliance documentation provided.",
        "provider": { "@id": "https://www.wernexpestcontrol.com/#business" },
        "areaServed": { "@type": "State", "name": "Utah" },
        "serviceType": "Commercial Pest Control",
        "url": "https://www.wernexpestcontrol.com/services.html#commercial"
      },
      {
        "@type": "Service",
        "@id": "https://www.wernexpestcontrol.com/services.html#termites",
        "name": "Termite Solutions",
        "description": "Advanced liquid barrier termite treatments, WDI inspections for real estate transactions, pre-construction treatments, and annual monitoring programs.",
        "provider": { "@id": "https://www.wernexpestcontrol.com/#business" },
        "areaServed": { "@type": "State", "name": "Utah" },
        "serviceType": "Termite Control",
        "url": "https://www.wernexpestcontrol.com/services.html#termites"
      },
      {
        "@type": "Service",
        "@id": "https://www.wernexpestcontrol.com/services.html#rodent",
        "name": "Rodent Control",
        "description": "Three-step rodent control: removal of existing mice and rats, exclusion sealing of all entry points, and ongoing monitoring stations.",
        "provider": { "@id": "https://www.wernexpestcontrol.com/#business" },
        "areaServed": { "@type": "State", "name": "Utah" },
        "serviceType": "Rodent Control",
        "url": "https://www.wernexpestcontrol.com/services.html#rodent"
      },
      {
        "@type": "FAQPage",
        "@id": "https://www.wernexpestcontrol.com/services.html#faq",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "What pest control services does Wernex offer?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Wernex offers four core services: residential pest control (quarterly home protection plans), commercial pest management (custom programs for businesses), termite solutions (liquid barrier treatments and WDI inspections), and rodent control (exclusion sealing, trapping, and monitoring). All services are available across St. George, Washington, Hurricane, and Southern Utah."
            }
          },
          {
            "@type": "Question",
            "name": "Does Wernex offer free pest inspections?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Yes. Wernex provides free inspections for all service types — residential, commercial, termite, and rodent. Our licensed technician will assess your property, identify the problem, and recommend the best treatment plan with no obligation. Call (435) 673-9503 to schedule."
            }
          },
          {
            "@type": "Question",
            "name": "How often does Wernex treat for residential pest control?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Residential plans include quarterly treatments, plus emergency callbacks between scheduled visits at no extra charge. Treatments are seasonally adjusted based on local pest pressure in Southern Utah — for example, increased scorpion and ant focus during warmer months."
            }
          }
        ]
      }
    ]
  }`;
---
<BaseLayout title={title} description={description} canonical={canonical} og={og} schema={schema} active={active}>
<!-- ═══ AI SUMMARY BLOCK (Layer 1 §1.1) ═══ -->
  <section class="section" style="padding-bottom: 0;">
    <div class="container">
      <div class="reveal" style="max-width: 820px; margin: 0 auto; background: var(--gray-light, #f5f5f5); border-radius: 12px; padding: 24px 28px;">
        <p style="margin:0; color: var(--dark, #1a1a1a); line-height: 1.7;"><strong>Wernex Termite &amp; Pest Control</strong> provides four core pest control services to homes and businesses across St. George, Washington, Hurricane, and <a href="pest-control-southern-utah.html">all of Southern Utah</a>: <a href="#residential">residential pest control</a>, <a href="#commercial">commercial pest management</a>, <a href="#termites">termite solutions</a>, and <a href="#rodent">rodent control</a>. Every service includes a free inspection, eco-friendly IPM treatment options, and our 30-day satisfaction guarantee. <a href="tel:+14356739503">Call (435) 673-9503</a> for same-day scheduling.</p>
      </div>
    </div>
  </section>

  <!-- SERVICE SECTIONS -->
  <section class="section" id="residential">
    <div class="container">
      <div class="service-detail">
        <div>
          <div class="two-col" style="gap: 32px;">
            <div class="reveal">
              <span class="section-label">Residential</span>
              <h2>Home Pest Control in Southern Utah</h2>
              <p style="margin: 16px 0; color: var(--gray);">Year-round protection plans designed for your home. We treat the interior, exterior perimeter, and all common entry points to create an invisible barrier against pests — including <a href="ant-control-st-george.html">ants</a>, <a href="spider-control-st-george.html">spiders</a>, scorpions, <a href="wasp-removal-st-george.html">wasps</a>, and cockroaches common in the St. George and Washington County area.</p>
              <p style="color: var(--gray);">Plans include quarterly treatments, emergency callbacks, and seasonal adjustments for local pest pressure. Learn more about the pests we treat in our <a href="pest-library.html">pest library</a>, or read <a href="testimonials.html">what homeowners say</a> about our service.</p>
              <div style="margin-top: 20px;">
                <a href="contact.html" class="btn btn--primary btn--sm">Schedule Free Inspection →</a>
              </div>
            </div>
            <div class="reveal">
              <img src="images/23.webp" alt="Wernex technician spraying home exterior perimeter for pest control in Southern Utah" class="service-img service-img--tall" loading="lazy">
            </div>
          </div>
          <div class="two-col" style="gap: 32px; margin-top: 48px;">
            <div class="reveal">
              <img src="images/26.webp" alt="Interior pest control treatment in kitchen area — eco-friendly products" class="service-img service-img--wide" loading="lazy">
            </div>
          </div>
        </div>

        <!-- ═══ CAL.COM BOOKING SIDEBAR ═══ -->
        <aside class="reveal" style="position: sticky; top: 96px;">
          <div class="quote-form">
            <h3>Book a Free Consultation</h3>
            <p>Pick a time that works for you — we'll confirm within minutes.</p>
            <div id="cal-booking-services" style="width:100%; min-height: 600px; overflow:scroll;"></div>
            <script type="text/javascript">
              (function (C, A, L) {
                let p = function (a, ar) { a.q.push(ar); };
                let d = C.document;
                C.Cal = C.Cal || function () {
                  let cal = C.Cal;
                  let ar = arguments;
                  if (!cal.loaded) {
                    cal.ns = {};
                    cal.q = cal.q || [];
                    d.head.appendChild(d.createElement("script")).src = A;
                    cal.loaded = true;
                  }
                  if (ar[0] === L) {
                    const api = function () { p(api, arguments); };
                    const namespace = ar[1];
                    api.q = api.q || [];
                    typeof namespace === "string"
                      ? (cal.ns[namespace] = api) && p(api, ar)
                      : p(cal, ar);
                    return;
                  }
                  p(cal, ar);
                };
              })(window, "https://app.cal.com/embed/embed.js", "init");
              Cal("init", { origin: "https://app.cal.com" });
              Cal("inline", {
                elementOrSelector: "#cal-booking-services",
                calLink: "wernexpestcontrol/free-consultation",
              });
              Cal("ui", {
                styles: { branding: { brandColor: "#2e7d32" } },
                hideEventTypeDetails: false,
              });
            </script>
            <p style="text-align: center; margin-top: 12px; font-size: 0.82rem; color: var(--gray);">
              🔒 Your information is secure and never shared.
            </p>
          </div>
        </aside>

      </div>
    </div>
  </section>

  <hr class="divider">

  <section class="section" id="commercial">
    <div class="container">
      <div class="two-col reveal">
        <div>
          <img src="images/24.webp" alt="Commercial pest control inspection in restaurant kitchen facility — Southern Utah" class="service-img service-img--tall" loading="lazy">
        </div>
        <div>
          <span class="section-label">Commercial</span>
          <h2>Business Pest Management</h2>
          <p style="margin: 16px 0; color: var(--gray);">Customized programs for restaurants, hotels, offices, warehouses, and healthcare facilities across St. George and Washington County. We help you meet health code requirements and protect your reputation.</p>
          <p style="color: var(--gray);">Discreet service, detailed documentation, and flexible scheduling around your business hours. See our <a href="testimonials.html">commercial client reviews</a> or learn <a href="about.html">about our 30+ years of experience</a>.</p>
          <a href="contact.html" class="btn btn--primary btn--sm" style="margin-top: 20px;">Request Commercial Quote →</a>
        </div>
      </div>
    </div>
  </section>

  <hr class="divider">

  <section class="section section--alt" id="termites">
    <div class="container">
      <div class="two-col reveal">
        <div>
          <span class="section-label">Termite Solutions</span>
          <h2>Stop Termites Before They Stop You</h2>
          <p style="margin: 16px 0; color: var(--gray);">We use advanced liquid barrier treatments to protect your home's structure. Every treatment comes with a damage warranty. Services include WDI inspections for real estate transactions, pre-construction treatments, and annual monitoring programs.</p>
          <p style="color: var(--gray);">Read our blog post on <a href="blog.html">what to expect during a termite inspection</a>, or browse our <a href="pest-library.html#termites">termite identification guide</a>.</p>
          <a href="contact.html" class="btn btn--primary btn--sm" style="margin-top: 20px;">Schedule Termite Inspection →</a>
        </div>
        <div>
          <img src="images/23.webp" alt="Liquid barrier termite treatment around home foundation in St. George Utah" class="service-img service-img--tall" loading="lazy">
        </div>
      </div>
    </div>
  </section>

  <hr class="divider">

  <section class="section section--alt" id="rodent">
    <div class="container">
      <div class="two-col reveal">
        <div>
          <span class="section-label">Rodent Control</span>
          <h2>Mice &amp; Rats — Exclusion, Trapping &amp; Monitoring</h2>
          <p style="margin: 16px 0; color: var(--gray);">Our three-step approach: remove existing rodents, seal all entry points with exclusion materials, and set up monitoring stations. No more scratching in the walls. Effective for homes and commercial properties across Southern Utah.</p>
          <p style="color: var(--gray);">Learn to identify signs of rodent activity in our <a href="pest-library.html#rodents">pest library</a>, or <a href="contact.html">schedule your free rodent inspection</a>.</p>
          <a href="contact.html" class="btn btn--primary btn--sm" style="margin-top: 20px;">Schedule Rodent Inspection →</a>
        </div>
        <div>
          <img src="images/30.webp" alt="Rodent exclusion work — sealing roof line entry points to prevent mice and rats" class="service-img service-img--tall" loading="lazy">
        </div>
      </div>
    </div>
  </section>

  <hr class="divider">

  <!-- ═══ FAQ SECTION (Layer 2 §1.1) ═══ -->
  <section class="section">
    <div class="container">
      <div class="text-center reveal">
        <span class="section-label">Common Questions</span>
        <h2>Services FAQ</h2>
      </div>
      <div style="max-width: 800px; margin: 36px auto 0;">
        <div class="faq-item reveal" style="border-bottom: 1px solid var(--gray-light); padding: 24px 0;">
          <h3 style="margin-bottom: 8px;">What pest control services does Wernex offer?</h3>
          <p style="color: var(--gray);">Wernex offers four core services: <a href="#residential">residential pest control</a> (quarterly home protection plans), <a href="#commercial">commercial pest management</a> (custom programs for businesses), <a href="#termites">termite solutions</a> (liquid barrier treatments and WDI inspections), and <a href="#rodent">rodent control</a> (exclusion sealing, trapping, and monitoring). All services are available across St. George, Washington, Hurricane, and Southern Utah.</p>
        </div>
        <div class="faq-item reveal" style="border-bottom: 1px solid var(--gray-light); padding: 24px 0;">
          <h3 style="margin-bottom: 8px;">Does Wernex offer free pest inspections?</h3>
          <p style="color: var(--gray);">Yes. Wernex provides free inspections for all service types. Our licensed technician will assess your property, identify the problem, and recommend the best treatment plan with no obligation. <a href="contact.html">Schedule online</a> or call <a href="tel:+14356739503">(435) 673-9503</a>.</p>
        </div>
        <div class="faq-item reveal" style="padding: 24px 0;">
          <h3 style="margin-bottom: 8px;">How often does Wernex treat for residential pest control?</h3>
          <p style="color: var(--gray);">Residential plans include quarterly treatments, plus emergency callbacks between scheduled visits at no extra charge. Treatments are seasonally adjusted based on local pest pressure in Southern Utah — for example, increased scorpion and ant focus during warmer months.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section--dark">
    <div class="container">
      <div class="cta-banner reveal" style="background: transparent; padding: 0; box-shadow: none;">
        <div>
          <h2>Not Sure What You Need?</h2>
          <p>Our free inspection will identify the problem and recommend the best solution — no obligation. 4.9★ rated on Google.</p>
        </div>
        <div class="cta-banner__buttons">
          <a href="contact.html" class="btn btn--primary">Get Your Free Quote →</a>
          <a href="tel:+14356739503" class="btn btn--white">📞 (435) 673-9503</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ RELATED PEST CONTROL SERVICES (Internal linking hub §4.2) ═══ -->
  <section class="section" style="padding-top:40px; padding-bottom:40px; background:var(--gray-light, #f5f5f5);">
    <div class="container" style="max-width: 880px;">
      <div class="text-center reveal" style="margin-bottom: 20px;">
        <span class="section-label">Specialized Services</span>
        <h3 style="margin-top: 8px; margin-bottom: 0;">Pest-Specific &amp; Regional Pages</h3>
      </div>
      <ul style="list-style:none; padding:0; margin:0; display:flex; flex-wrap:wrap; justify-content:center; gap:12px 28px;">
        <li><a href="pest-control-southern-utah.html">Southern Utah Service Area</a></li>
        <li><a href="ant-control-st-george.html">Ant Control in St. George</a></li>
        <li><a href="spider-control-st-george.html">Spider Control St. George</a></li>
        <li><a href="wasp-removal-st-george.html">Wasp &amp; Bee Removal</a></li>
      </ul>
    </div>
  </section>

  <!-- ═══ FOOTER (Standardized) ═══ -->
</BaseLayout>
