---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Spider Control in St. George UT — Black Widow &amp; Desert Spider Removal | Wernex';
const description = 'Expert spider control in St. George, Utah. Wernex eliminates black widows, brown recluses, and desert spiders with targeted treatments. Same-day service. Call (435) 673-9503.';
const canonical = 'https://www.wernexpestcontrol.com/spider-control-st-george.html';
const active = '';
const og = { "og:title": 'Spider Control in St. George UT — Black Widow & Desert Spider Removal | Wernex', "og:description": 'Expert spider control in St. George, Utah. Wernex eliminates black widows, brown recluses, and desert spiders with targeted treatments. Same-day service. Call (435) 673-9503.', "og:type": 'website', "og:url": 'https://www.wernexpestcontrol.com/spider-control-st-george.html', "og:locale": 'en_US', "og:site_name": 'Wernex Termite & Pest Control' };
const schema = `{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "@id": "https://www.wernexpestcontrol.com/#business",
      "name": "Wernex Termite & Pest Control, Inc.",
      "url": "https://www.wernexpestcontrol.com/",
      "telephone": "+1-435-673-9503",
      "email": "wernexpestcontrol@gmail.com",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "6097 Dry Fork Canyon Rd",
        "addressLocality": "Vernal",
        "addressRegion": "UT",
        "postalCode": "84078",
        "addressCountry": "US"
      },
      "priceRange": "$"
    },
    {
      "@type": "WebPage",
      "@id": "https://www.wernexpestcontrol.com/spider-control-st-george.html#webpage",
      "url": "https://www.wernexpestcontrol.com/spider-control-st-george.html",
      "name": "Spider Control in St. George UT \\u2014 Black Widow & Desert Spider Removal | Wernex",
      "isPartOf": {
        "@id": "https://www.wernexpestcontrol.com/#website"
      },
      "about": {
        "@id": "https://www.wernexpestcontrol.com/#business"
      },
      "breadcrumb": {
        "@id": "https://www.wernexpestcontrol.com/spider-control-st-george.html#breadcrumb"
      }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.wernexpestcontrol.com/spider-control-st-george.html#breadcrumb",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://www.wernexpestcontrol.com/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Spider Control St. George",
          "item": "https://www.wernexpestcontrol.com/spider-control-st-george.html"
        }
      ]
    },
    {
      "@type": "FAQPage",
      "@id": "https://www.wernexpestcontrol.com/spider-control-st-george.html#faq",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Are black widow spiders common in St. George?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. Black widows are very common in Southern Utah, especially in garages, sheds, woodpiles, and under patio furniture. They prefer dark, undisturbed areas. Wernex technicians are trained to locate and eliminate black widow populations safely."
          }
        },
        {
          "@type": "Question",
          "name": "Are brown recluse spiders found in Southern Utah?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Brown recluses are less common than black widows in the St. George area but are occasionally found in storage areas, closets, and boxes. Their bites can cause serious tissue damage, making professional identification and treatment important."
          }
        },
        {
          "@type": "Question",
          "name": "How does Wernex treat for spiders?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "We use a three-part approach: web removal and egg sac destruction, targeted residual sprays in harborage areas, and exterior perimeter barrier treatment. We also treat for the insects spiders feed on \\u2014 eliminating their food source reduces spider populations long-term."
          }
        },
        {
          "@type": "Question",
          "name": "How often should I get spider treatment in Southern Utah?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "We recommend quarterly treatments to maintain continuous protection, especially during the warmer months when spider activity peaks. Our protection plans include re-service at no cost if spiders return between treatments."
          }
        }
      ]
    }
  ]
}`;
---
<BaseLayout title={title} description={description} canonical={canonical} og={og} schema={schema} active={active}>
<!-- ═══ HERO ═══ -->
  <section class="hero" style="min-height:auto;padding:160px 0 80px;">
    <div class="hero__bg-gradient"></div>
    <div class="container">
      <div class="hero__content reveal" style="--delay:0;max-width:800px;">
        <div class="hero__pre-label">
          <span class="hero__dot"></span>
          Licensed &amp; Insured • 30+ Years
        </div>
        <h1>Spider Control<br><span>St. George &amp; Southern Utah</span></h1>

        <!-- ═══ SEO: AI SUMMARY BLOCK ═══ -->
        <p>Wernex Termite &amp; Pest Control provides expert spider control in St. George and across Southern Utah. Our licensed technicians eliminate black widows, brown recluses, wolf spiders, and other desert spiders using targeted treatments, web removal, and exterior barrier applications. We use eco-friendly, IPM-first methods safe for families and pets. Same-day inspections available. Call (435) 673-9503.</p>

        <div class="hero__buttons" style="margin-top:28px;">
          <a href="contact.html" class="btn btn--primary">Get a Free Quote →</a>
          <a href="tel:+14356739503" class="btn btn--white">📞 (435) 673-9503</a>
        </div>
        <div class="hero__badges" style="margin-top:24px;">
          <div class="hero__badge"><div class="hero__badge-icon">✓</div><span>Licensed &amp; Insured</span></div>
          <div class="hero__badge"><div class="hero__badge-icon">🌿</div><span>Eco-Friendly</span></div>
          <div class="hero__badge"><div class="hero__badge-icon">⏱️</div><span>Same-Day Service</span></div>
          <div class="hero__badge"><div class="hero__badge-icon">🔒</div><span>Satisfaction Guaranteed</span></div>
        </div>
      </div>
    </div>
  </section>

    <section class="section">
      <div class="container">
        <div class="text-center reveal">
          <span class="section-label">Know Your Spiders</span>
          <h2>Dangerous &amp; Nuisance Spiders in Southern Utah</h2>
          <p class="mx-auto" style="margin-top:12px;color:var(--gray);">Southern Utah's desert climate is ideal spider habitat. Knowing which species are dangerous helps you protect your family.</p>
        </div>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:24px;margin-top:48px;">
          <div class="card reveal"><div class="card__body">
            <h3>⚠️ Black Widow</h3>
            <p style="color:var(--gray);">Glossy black with a red hourglass marking. Found in garages, sheds, and under outdoor furniture. Venomous — bites require medical attention. The most medically significant spider in Utah.</p>
          </div></div>
          <div class="card reveal"><div class="card__body">
            <h3>⚠️ Brown Recluse</h3>
            <p style="color:var(--gray);">Light brown with a violin-shaped marking. Hides in storage boxes, closets, and undisturbed areas. Bites can cause necrotic tissue damage. Less common but present in Southern Utah.</p>
          </div></div>
          <div class="card reveal"><div class="card__body">
            <h3>🕷️ Wolf Spider</h3>
            <p style="color:var(--gray);">Large, fast-moving ground hunters that enter homes seeking prey. Non-venomous to humans but alarming due to size. Very common in St. George homes and garages.</p>
          </div></div>
          <div class="card reveal"><div class="card__body">
            <h3>🕸️ Desert Recluse</h3>
            <p style="color:var(--gray);">Native to Southern Utah's red rock terrain. Similar to brown recluse but more commonly found outdoors. Can enter homes through gaps around doors and windows.</p>
          </div></div>
        </div>
      </div>
    </section>

    <section class="section--alt section">
      <div class="container">
        <div class="text-center reveal">
          <span class="section-label">Our Approach</span>
          <h2>How Wernex Eliminates Spiders</h2>
        </div>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:24px;margin-top:48px;">
          <div class="card reveal"><div class="card__body">
            <h3>Step 1: Sweep &amp; Destroy</h3>
            <p style="color:var(--gray);">We physically remove all webs and egg sacs from eaves, corners, garages, and crawl spaces. Destroying egg sacs prevents the next generation from hatching — each sac can contain 100–400 spiderlings.</p>
          </div></div>
          <div class="card reveal"><div class="card__body">
            <h3>Step 2: Targeted Treatment</h3>
            <p style="color:var(--gray);">Residual insecticide applied to harborage zones — dark corners, behind furniture, inside storage areas, and along baseboards where spiders travel and hide.</p>
          </div></div>
          <div class="card reveal"><div class="card__body">
            <h3>Step 3: Barrier &amp; Prey Reduction</h3>
            <p style="color:var(--gray);">Exterior perimeter barrier treatment eliminates the insects spiders feed on. No food source means spiders leave. This is the key to long-term spider reduction, not just killing individual spiders.</p>
          </div></div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="text-center reveal">
          <span class="section-label">Related Services</span>
          <h2>More Pest Solutions from Wernex</h2>
        </div>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:16px;margin-top:32px;">
          <a href="pest-control-southern-utah.html" class="btn btn--outline" style="text-align:center;">🛡️ All Southern Utah Services</a>
          <a href="ant-control-st-george.html" class="btn btn--outline" style="text-align:center;">🐜 Ant Control</a>
          <a href="scorpion-control-st-george.html" class="btn btn--outline" style="text-align:center;">🦂 Scorpion Control</a>
          <a href="pest-library.html" class="btn btn--outline" style="text-align:center;">📚 Pest Library</a>
        </div>
      </div>
    </section>

    <!-- ═══ FAQ SECTION ═══ -->
    <section class="section--alt section">
      <div class="container">
        <div class="text-center reveal">
          <span class="section-label">Common Questions</span>
          <h2>Frequently Asked Questions</h2>
        </div>
        <div style="max-width:800px;margin:40px auto 0;">

        <details class="reveal" style="background:var(--off-white);border-radius:var(--radius);padding:20px 24px;margin-bottom:12px;cursor:pointer;">
          <summary style="font-family:var(--font-display);font-weight:700;font-size:1.05rem;color:var(--text-dark);">Are black widow spiders common in St. George?</summary>
          <p style="margin-top:12px;color:var(--text-body);max-width:65ch;">Yes. Black widows are very common in Southern Utah, especially in garages, sheds, woodpiles, and under patio furniture. They prefer dark, undisturbed areas. Wernex technicians are trained to locate and eliminate black widow populations safely.</p>
        </details>
        <details class="reveal" style="background:var(--off-white);border-radius:var(--radius);padding:20px 24px;margin-bottom:12px;cursor:pointer;">
          <summary style="font-family:var(--font-display);font-weight:700;font-size:1.05rem;color:var(--text-dark);">Are brown recluse spiders found in Southern Utah?</summary>
          <p style="margin-top:12px;color:var(--text-body);max-width:65ch;">Brown recluses are less common than black widows in the St. George area but are occasionally found in storage areas, closets, and boxes. Their bites can cause serious tissue damage, making professional identification and treatment important.</p>
        </details>
        <details class="reveal" style="background:var(--off-white);border-radius:var(--radius);padding:20px 24px;margin-bottom:12px;cursor:pointer;">
          <summary style="font-family:var(--font-display);font-weight:700;font-size:1.05rem;color:var(--text-dark);">How does Wernex treat for spiders?</summary>
          <p style="margin-top:12px;color:var(--text-body);max-width:65ch;">We use a three-part approach: web removal and egg sac destruction, targeted residual sprays in harborage areas, and exterior perimeter barrier treatment. We also treat for the insects spiders feed on — eliminating their food source reduces spider populations long-term.</p>
        </details>
        <details class="reveal" style="background:var(--off-white);border-radius:var(--radius);padding:20px 24px;margin-bottom:12px;cursor:pointer;">
          <summary style="font-family:var(--font-display);font-weight:700;font-size:1.05rem;color:var(--text-dark);">How often should I get spider treatment in Southern Utah?</summary>
          <p style="margin-top:12px;color:var(--text-body);max-width:65ch;">We recommend quarterly treatments to maintain continuous protection, especially during the warmer months when spider activity peaks. Our protection plans include re-service at no cost if spiders return between treatments.</p>
        </details>
        </div>
      </div>
    </section>

    <!-- ═══ CTA SECTION ═══ -->
    <section class="section--dark section">
      <div class="container text-center">
        <h2>Ready to Get Started?</h2>
        <p class="mx-auto" style="margin-top:12px;color:rgba(255,255,255,0.8);">Call Wernex today for a free inspection and quote. Same-day service available throughout Southern Utah.</p>
        <div style="margin-top:28px;display:flex;gap:16px;justify-content:center;flex-wrap:wrap;">
          <a href="tel:+14356739503" class="btn btn--white">📞 (435) 673-9503</a>
          <a href="contact.html" class="btn btn--primary">Schedule Online →</a>
        </div>
      </div>
    </section>

  <!-- ═══ FOOTER ═══ -->
</BaseLayout>
