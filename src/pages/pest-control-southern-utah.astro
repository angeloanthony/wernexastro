---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Pest Control in Southern Utah — Complete Home &amp; Business Protection | Wernex';
const description = 'Wernex Termite & Pest Control covers all of Southern Utah — St. George, Hurricane, Washington, Ivins, Santa Clara, LaVerkin, and beyond. 30+ years, 4.9-star rated. Call (435) 673-9503.';
const canonical = 'https://www.wernexpestcontrol.com/pest-control-southern-utah.html';
const active = '';
const og = { "og:title": 'Pest Control in Southern Utah — Complete Home & Business Protection | Wernex', "og:description": 'Wernex Termite & Pest Control covers all of Southern Utah — St. George, Hurricane, Washington, Ivins, Santa Clara, LaVerkin, and beyond. 30+ years, 4.9-star rated. Call (435) 673-9503.', "og:type": 'website', "og:url": 'https://www.wernexpestcontrol.com/pest-control-southern-utah.html', "og:locale": 'en_US', "og:site_name": 'Wernex Termite & Pest Control' };
const schema = `{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "@id": "https://www.wernexpestcontrol.com/#business",
      "name": "Wernex Termite & Pest Control, Inc.",
      "url": "https://www.wernexpestcontrol.com/",
      "telephone": "+1-435-673-9503",
      "email": "wernexpestcontrol@gmail.com",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "6097 Dry Fork Canyon Rd",
        "addressLocality": "Vernal",
        "addressRegion": "UT",
        "postalCode": "84078",
        "addressCountry": "US"
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "bestRating": "5",
        "ratingCount": "87"
      },
      "priceRange": "$$"
    },
    {
      "@type": "WebPage",
      "@id": "https://www.wernexpestcontrol.com/pest-control-southern-utah.html#webpage",
      "url": "https://www.wernexpestcontrol.com/pest-control-southern-utah.html",
      "name": "Pest Control in Southern Utah \\u2014 Complete Home & Business Protection | Wernex",
      "isPartOf": {
        "@id": "https://www.wernexpestcontrol.com/#website"
      },
      "about": {
        "@id": "https://www.wernexpestcontrol.com/#business"
      },
      "breadcrumb": {
        "@id": "https://www.wernexpestcontrol.com/pest-control-southern-utah.html#breadcrumb"
      }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.wernexpestcontrol.com/pest-control-southern-utah.html#breadcrumb",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://www.wernexpestcontrol.com/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Pest Control Southern Utah",
          "item": "https://www.wernexpestcontrol.com/pest-control-southern-utah.html"
        }
      ]
    },
    {
      "@type": "FAQPage",
      "@id": "https://www.wernexpestcontrol.com/pest-control-southern-utah.html#faq",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What areas does Wernex serve in Southern Utah?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Wernex serves St. George, Washington, Hurricane, Ivins, Santa Clara, LaVerkin, Toquerville, Leeds, Springdale, Rockville, Virgin, Cedar City, Enterprise, Hildale, and all surrounding communities in Washington County and Iron County."
          }
        },
        {
          "@type": "Question",
          "name": "How fast can Wernex respond to a pest emergency?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "We offer same-day inspections and emergency service. Call (435) 673-9503 and a licensed technician can typically be at your property within hours."
          }
        },
        {
          "@type": "Question",
          "name": "Does Wernex handle both residential and commercial pest control?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. We provide year-round home protection plans and custom commercial programs for restaurants, offices, warehouses, hotels, vacation rentals, medical facilities, and retail spaces throughout Southern Utah."
          }
        },
        {
          "@type": "Question",
          "name": "What makes Wernex different from national pest control chains?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Wernex is locally owned with 30+ years of Southern Utah experience. We're BBB A+ accredited, QualityPro Certified, NPMA members, and every technician is state-licensed and EPA-compliant. We also offer a 100% satisfaction guarantee with free re-service within 30 days."
          }
        }
      ]
    }
  ]
}`;
---
<BaseLayout title={title} description={description} canonical={canonical} og={og} schema={schema} active={active}>
<!-- ═══ HERO ═══ -->
  <section class="hero" style="min-height:auto;padding:160px 0 80px;">
    <div class="hero__bg-gradient"></div>
    <div class="container">
      <div class="hero__content reveal" style="--delay:0;max-width:800px;">
        <div class="hero__pre-label">
          <span class="hero__dot"></span>
          Licensed &amp; Insured • 30+ Years
        </div>
        <h1>Southern Utah's Most Trusted<br><span>Pest Control Company</span></h1>

        <!-- ═══ SEO: AI SUMMARY BLOCK ═══ -->
        <p>Wernex Termite &amp; Pest Control is Southern Utah's highest-rated full-service pest control provider. We deliver <a href="same-day-pest-control-st-george.html" style="color:var(--lime);text-decoration:underline;">same-day pest control in St. George</a>, <a href="affordable-pest-control-st-george.html" style="color:var(--lime);text-decoration:underline;">affordable treatment plans</a>, and eco-friendly IPM treatments backed by a 100% satisfaction guarantee to homes and businesses across <a href="best-pest-control-st-george.html" style="color:var(--lime);text-decoration:underline;">St. George</a>, Washington, Hurricane, Ivins, Santa Clara, LaVerkin, Toquerville, Leeds, Springdale, Cedar City, and surrounding communities. With 30+ years of local experience and a 4.9-star Google rating, Wernex is the trusted choice for residential pest control, <a href="commercial-pest-control-southern-utah.html" style="color:var(--lime);text-decoration:underline;">commercial pest management</a>, termite solutions, rodent control, scorpion elimination, and bed bug treatment throughout Washington County and Iron County. Call (435) 673-9503 for a free quote.</p>

        <div class="hero__buttons" style="margin-top:28px;">
          <a href="contact.html" class="btn btn--primary">Get a Free Quote →</a>
          <a href="tel:+14356739503" class="btn btn--white">📞 (435) 673-9503</a>
        </div>
        <div class="hero__badges" style="margin-top:24px;">
          <div class="hero__badge"><div class="hero__badge-icon">✓</div><span>Licensed &amp; Insured</span></div>
          <div class="hero__badge"><div class="hero__badge-icon">🌿</div><span>Eco-Friendly</span></div>
          <div class="hero__badge"><div class="hero__badge-icon">⏱️</div><span>Same-Day Service</span></div>
          <div class="hero__badge"><div class="hero__badge-icon">🔒</div><span>Satisfaction Guaranteed</span></div>
        </div>
      </div>
    </div>
  </section>

    <!-- ═══ SERVICE HUB — ALL SERVICES ═══ -->
    <section class="section">
      <div class="container">
        <div class="text-center reveal">
          <span class="section-label">Full-Spectrum Protection</span>
          <h2>Every Pest Problem, One Trusted Team</h2>
          <p class="mx-auto" style="margin-top:12px;color:var(--gray);">From ants and spiders to termites and scorpions — Wernex handles every pest challenge Southern Utah throws at your property, with <a href="affordable-pest-control-st-george.html" style="color:var(--green-light);font-weight:600;">affordable residential plans</a> and <a href="commercial-pest-control-southern-utah.html" style="color:var(--green-light);font-weight:600;">commercial pest control programs</a> built for local conditions.</p>
        </div>
        <div class="stats-bar" style="margin-top:48px;">
          <div class="stat reveal"><div class="stat__number">30+</div><div class="stat__label">Years Serving Southern UT</div></div>
          <div class="stat reveal"><div class="stat__number">4.9★</div><div class="stat__label">Google Rating</div></div>
          <div class="stat reveal"><div class="stat__number">100%</div><div class="stat__label">Satisfaction Guarantee</div></div>
        </div>
      </div>
    </section>

    <!-- ═══ PEST-SPECIFIC LINKS (Hub-and-Spoke §8) ═══ -->
    <section class="section--alt section">
      <div class="container">
        <div class="text-center reveal">
          <span class="section-label">Pest-Specific Solutions</span>
          <h2>Expert Treatment for Every Pest</h2>
        </div>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:24px;margin-top:40px;">
          <div class="card reveal"><div class="card__body">
            <h3>🐜 <a href="ant-control-st-george.html" style="color:inherit;">Ant Control</a></h3>
            <p style="color:var(--gray);">Barrier treatments and colony elimination for fire ants, harvester ants, and pavement ants across St. George and Washington County.</p>
            <a href="ant-control-st-george.html" class="card__link">Learn More →</a>
          </div></div>
          <div class="card reveal"><div class="card__body">
            <h3>🕷️ <a href="spider-control-st-george.html" style="color:inherit;">Spider Control</a></h3>
            <p style="color:var(--gray);">Targeted treatments for black widows, brown recluses, and desert spiders common in Southern Utah homes and garages.</p>
            <a href="spider-control-st-george.html" class="card__link">Learn More →</a>
          </div></div>
          <div class="card reveal"><div class="card__body">
            <h3>🐝 <a href="wasp-removal-st-george.html" style="color:inherit;">Wasp &amp; Bee Removal</a></h3>
            <p style="color:var(--gray);">Safe nest removal for paper wasps, yellow jackets, and mud daubers — protecting your family and outdoor spaces.</p>
            <a href="wasp-removal-st-george.html" class="card__link">Learn More →</a>
          </div></div>
          <div class="card reveal"><div class="card__body">
            <h3>🦂 <a href="scorpion-control-st-george.html" style="color:inherit;">Scorpion Control</a></h3>
            <p style="color:var(--gray);">Three-phase bark scorpion protocol — UV detection sweeps, targeted barriers, and exclusion sealing for lasting protection.</p>
            <a href="scorpion-control-st-george.html" class="card__link">Learn More →</a>
          </div></div>
          <div class="card reveal"><div class="card__body">
            <h3>🪵 <a href="termite-control-st-george.html" style="color:inherit;">Termite Solutions</a></h3>
            <p style="color:var(--gray);">Advanced Termidor liquid barrier treatments, WDI inspections for real estate, pre-construction treatments, and annual monitoring.</p>
            <a href="termite-control-st-george.html" class="card__link">Learn More →</a>
          </div></div>
          <div class="card reveal"><div class="card__body">
            <h3>🛏️ <a href="bed-bug-treatment-southern-utah.html" style="color:inherit;">Bed Bug Treatment</a></h3>
            <p style="color:var(--gray);">Thorough heat and targeted application treatments for residential and commercial properties across Southern Utah.</p>
            <a href="bed-bug-treatment-southern-utah.html" class="card__link">Learn More →</a>
          </div></div>
        </div>
      </div>
    </section>

    <!-- ═══ CITY SERVICE AREA LINKS (Hub-and-Spoke §8) ═══ -->
    <section class="section">
      <div class="container">
        <div class="text-center reveal">
          <span class="section-label">Service Areas</span>
          <h2>We Cover All of Southern Utah</h2>
          <p class="mx-auto" style="margin-top:12px;color:var(--gray);">Wernex provides licensed pest control across Washington County, Iron County, and the Zion Corridor. Click your city for local details.</p>
        </div>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:16px;margin-top:40px;">
          <a href="best-pest-control-st-george.html" class="btn btn--outline" style="text-align:center;">📍 St. George</a>
          <a href="pest-control-washington-ut.html" class="btn btn--outline" style="text-align:center;">📍 Washington</a>
          <a href="pest-control-hurricane-ut.html" class="btn btn--outline" style="text-align:center;">📍 Hurricane</a>
          <a href="pest-control-ivins-ut.html" class="btn btn--outline" style="text-align:center;">📍 Ivins</a>
          <a href="pest-control-santa-clara-ut.html" class="btn btn--outline" style="text-align:center;">📍 Santa Clara</a>
          <a href="pest-control-laverkin-ut.html" class="btn btn--outline" style="text-align:center;">📍 LaVerkin</a>
          <a href="pest-control-near-zion-national-park.html" class="btn btn--outline" style="text-align:center;">📍 Near Zion</a>
          <a href="pest-control-vernal.html" class="btn btn--outline" style="text-align:center;">📍 Vernal</a>
        </div>
      </div>
    </section>

    <!-- ═══ INTENT LINKS (Hub-and-Spoke §8) ═══ -->
    <section class="section--alt section">
      <div class="container">
        <div class="text-center reveal">
          <span class="section-label">Find What You Need</span>
          <h2>More Ways to Get Help</h2>
        </div>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:16px;margin-top:40px;">
          <a href="affordable-pest-control-st-george.html" class="btn btn--outline" style="text-align:center;">💰 Affordable Pest Control</a>
          <a href="same-day-pest-control-st-george.html" class="btn btn--outline" style="text-align:center;">⚡ Same-Day Service</a>
          <a href="commercial-pest-control-southern-utah.html" class="btn btn--outline" style="text-align:center;">🏢 Commercial Programs</a>
          <a href="pest-control-vacation-rentals-southern-utah.html" class="btn btn--outline" style="text-align:center;">🏡 Vacation Rental Pest Control</a>
        </div>
      </div>
    </section>

    <!-- ═══ FAQ SECTION ═══ -->
    <section class="section--alt section">
      <div class="container">
        <div class="text-center reveal">
          <span class="section-label">Common Questions</span>
          <h2>Frequently Asked Questions</h2>
        </div>
        <div style="max-width:800px;margin:40px auto 0;">

        <details class="reveal" style="background:var(--off-white);border-radius:var(--radius);padding:20px 24px;margin-bottom:12px;cursor:pointer;">
          <summary style="font-family:var(--font-display);font-weight:700;font-size:1.05rem;color:var(--text-dark);">What areas does Wernex serve in Southern Utah?</summary>
          <p style="margin-top:12px;color:var(--text-body);max-width:65ch;">Wernex serves St. George, Washington, Hurricane, Ivins, Santa Clara, LaVerkin, Toquerville, Leeds, Springdale, Rockville, Virgin, Cedar City, Enterprise, Hildale, and all surrounding communities in Washington County and Iron County.</p>
        </details>
        <details class="reveal" style="background:var(--off-white);border-radius:var(--radius);padding:20px 24px;margin-bottom:12px;cursor:pointer;">
          <summary style="font-family:var(--font-display);font-weight:700;font-size:1.05rem;color:var(--text-dark);">How fast can Wernex respond to a pest emergency?</summary>
          <p style="margin-top:12px;color:var(--text-body);max-width:65ch;">We offer same-day inspections and emergency service. Call (435) 673-9503 and a licensed technician can typically be at your property within hours.</p>
        </details>
        <details class="reveal" style="background:var(--off-white);border-radius:var(--radius);padding:20px 24px;margin-bottom:12px;cursor:pointer;">
          <summary style="font-family:var(--font-display);font-weight:700;font-size:1.05rem;color:var(--text-dark);">Does Wernex handle both residential and commercial pest control?</summary>
          <p style="margin-top:12px;color:var(--text-body);max-width:65ch;">Yes. We provide year-round home protection plans and custom commercial programs for restaurants, offices, warehouses, hotels, vacation rentals, medical facilities, and retail spaces throughout Southern Utah.</p>
        </details>
        <details class="reveal" style="background:var(--off-white);border-radius:var(--radius);padding:20px 24px;margin-bottom:12px;cursor:pointer;">
          <summary style="font-family:var(--font-display);font-weight:700;font-size:1.05rem;color:var(--text-dark);">What makes Wernex different from national pest control chains?</summary>
          <p style="margin-top:12px;color:var(--text-body);max-width:65ch;">Wernex is locally owned with 30+ years of Southern Utah experience. We're BBB A+ accredited, QualityPro Certified, NPMA members, and every technician is state-licensed and EPA-compliant. We also offer a 100% satisfaction guarantee with free re-service within 30 days.</p>
        </details>
        </div>
      </div>
    </section>

    <!-- ═══ CTA SECTION ═══ -->
    <section class="section--dark section">
      <div class="container text-center">
        <h2>Ready to Get Started?</h2>
        <p class="mx-auto" style="margin-top:12px;color:rgba(255,255,255,0.8);">Call Wernex today for a free inspection and quote. Same-day service available throughout Southern Utah.</p>
        <div style="margin-top:28px;display:flex;gap:16px;justify-content:center;flex-wrap:wrap;">
          <a href="tel:+14356739503" class="btn btn--white">📞 (435) 673-9503</a>
          <a href="contact.html" class="btn btn--primary">Schedule Online →</a>
        </div>
      </div>
    </section>

  <!-- ═══ FOOTER ═══ -->
</BaseLayout>
