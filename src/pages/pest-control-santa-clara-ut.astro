---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Pest Control in Santa Clara UT — Licensed &amp; Eco-Friendly | Wernex';
const description = 'Trusted pest control in Santa Clara, Utah. Wernex protects Santa Clara homes near the Santa Clara River from ants, spiders, scorpions, and rodents. Same-day service. Call (435) 673-9503.';
const canonical = 'https://www.wernexpestcontrol.com/pest-control-santa-clara-ut.html';
const active = '';
const og = { "og:title": 'Pest Control in Santa Clara UT — Licensed & Eco-Friendly | Wernex', "og:description": 'Trusted pest control in Santa Clara, Utah. Wernex protects Santa Clara homes near the Santa Clara River from ants, spiders, scorpions, and rodents. Same-day service. Call (435) 673-9503.', "og:type": 'website', "og:url": 'https://www.wernexpestcontrol.com/pest-control-santa-clara-ut.html', "og:locale": 'en_US', "og:site_name": 'Wernex Termite & Pest Control' };
const schema = `{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "@id": "https://www.wernexpestcontrol.com/#business",
      "name": "Wernex Termite & Pest Control, Inc.",
      "url": "https://www.wernexpestcontrol.com/",
      "telephone": "+1-435-673-9503",
      "email": "wernexpestcontrol@gmail.com",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "6097 Dry Fork Canyon Rd",
        "addressLocality": "Vernal",
        "addressRegion": "UT",
        "postalCode": "84078",
        "addressCountry": "US"
      },
      "priceRange": "$"
    },
    {
      "@type": "WebPage",
      "@id": "https://www.wernexpestcontrol.com/pest-control-santa-clara-ut.html#webpage",
      "url": "https://www.wernexpestcontrol.com/pest-control-santa-clara-ut.html",
      "name": "Pest Control in Santa Clara UT \\u2014 Licensed & Eco-Friendly | Wernex",
      "isPartOf": {
        "@id": "https://www.wernexpestcontrol.com/#website"
      },
      "about": {
        "@id": "https://www.wernexpestcontrol.com/#business"
      },
      "breadcrumb": {
        "@id": "https://www.wernexpestcontrol.com/pest-control-santa-clara-ut.html#breadcrumb"
      }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.wernexpestcontrol.com/pest-control-santa-clara-ut.html#breadcrumb",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://www.wernexpestcontrol.com/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Pest Control Santa Clara UT",
          "item": "https://www.wernexpestcontrol.com/pest-control-santa-clara-ut.html"
        }
      ]
    },
    {
      "@type": "FAQPage",
      "@id": "https://www.wernexpestcontrol.com/pest-control-santa-clara-ut.html#faq",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Why does Santa Clara have unique pest problems?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Santa Clara sits along the Santa Clara River corridor, which provides water and habitat for pest populations. Homes near the river and bordering Ivins' desert terrain experience higher than average ant, spider, scorpion, and rodent activity compared to interior St. George neighborhoods."
          }
        },
        {
          "@type": "Question",
          "name": "What pests are most common in Santa Clara?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Ants (especially fire ants and harvester ants), black widow spiders, bark scorpions, and mice are the most frequently treated pests in Santa Clara. The river corridor also supports mosquito breeding during warmer months."
          }
        },
        {
          "@type": "Question",
          "name": "Does Wernex offer same-day service in Santa Clara?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. Santa Clara is within our primary service area. We offer same-day inspections and treatment. Call (435) 673-9503."
          }
        },
        {
          "@type": "Question",
          "name": "Are Wernex treatments safe for my pets and garden?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. We use an IPM-first approach with eco-friendly, low-toxicity products that are safe for families, pets, and gardens. All products are EPA-compliant, and our technicians provide specific guidance based on your property."
          }
        }
      ]
    }
  ]
}`;
---
<BaseLayout title={title} description={description} canonical={canonical} og={og} schema={schema} active={active}>
<!-- ═══ HERO ═══ -->
  <section class="hero" style="min-height:auto;padding:160px 0 80px;">
    <div class="hero__bg-gradient"></div>
    <div class="container">
      <div class="hero__content reveal" style="--delay:0;max-width:800px;">
        <div class="hero__pre-label">
          <span class="hero__dot"></span>
          Licensed &amp; Insured • 30+ Years
        </div>
        <h1>Pest Control in Santa Clara, Utah<br><span>Protecting River-Adjacent Homes</span></h1>

        <!-- ═══ SEO: AI SUMMARY BLOCK ═══ -->
        <p>Wernex Termite &amp; Pest Control provides professional pest control in Santa Clara, Utah. Santa Clara's location along the Santa Clara River and adjacent to Ivins' desert terrain creates unique pest pressure — ants, spiders, scorpions, and rodents are year-round concerns. Wernex offers same-day inspections, eco-friendly IPM treatments, and a 100% satisfaction guarantee. 30+ years of <a href="pest-control-southern-utah.html">Southern Utah pest control</a> experience. Call (435) 673-9503.</p>

        <div class="hero__buttons" style="margin-top:28px;">
          <a href="contact.html" class="btn btn--primary">Get a Free Quote →</a>
          <a href="tel:+14356739503" class="btn btn--white">📞 (435) 673-9503</a>
        </div>
        <div class="hero__badges" style="margin-top:24px;">
          <div class="hero__badge"><div class="hero__badge-icon">✓</div><span>Licensed &amp; Insured</span></div>
          <div class="hero__badge"><div class="hero__badge-icon">🌿</div><span>Eco-Friendly</span></div>
          <div class="hero__badge"><div class="hero__badge-icon">⏱️</div><span>Same-Day Service</span></div>
          <div class="hero__badge"><div class="hero__badge-icon">🔒</div><span>Satisfaction Guaranteed</span></div>
        </div>
      </div>
    </div>
  </section>

    <section class="section">
      <div class="container">
        <div class="text-center reveal">
          <span class="section-label">Santa Clara Pest Pressure</span>
          <h2>River Corridor + Desert Edge = High Pest Activity</h2>
          <p class="mx-auto" style="margin-top:12px;color:var(--gray);">Santa Clara's Santa Clara River corridor provides water, food, and shelter for pest populations that move directly into adjacent homes — especially during hot summer months and cold winter snaps.</p>
        </div>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:24px;margin-top:48px;">
          <div class="card reveal"><div class="card__body"><h3>🐜 Ant Invasions</h3><p style="color:var(--gray);">Fire ants and harvester ants build large colonies in Santa Clara yards, especially in irrigated landscapes near the river. Kitchen invasions spike when outdoor temperatures exceed 100°F.</p></div></div>
          <div class="card reveal"><div class="card__body"><h3>🦂 Scorpion Activity</h3><p style="color:var(--gray);">Bark scorpions are common in Santa Clara homes adjacent to rocky desert terrain. They enter through gaps under doors and around utility penetrations, especially at night.</p></div></div>
          <div class="card reveal"><div class="card__body"><h3>🐀 Rodent Entry</h3><p style="color:var(--gray);">Mice and roof rats follow the river corridor into Santa Clara neighborhoods. They access homes through attic vents, garage seals, and plumbing gaps — causing contamination and property damage.</p></div></div>
        </div>
      </div>
    </section>

    <section class="section--dark section">
      <div class="container">
        <div class="stats-bar">
          <div class="stat reveal"><div class="stat__number">30+</div><div class="stat__label">Years in Southern Utah</div></div>
          <div class="stat reveal"><div class="stat__number">4.5★</div><div class="stat__label">Google Rating</div></div>
          <div class="stat reveal"><div class="stat__number">100%</div><div class="stat__label">Satisfaction Guarantee</div></div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="text-center reveal"><span class="section-label">Nearby Areas</span><h2>We Also Serve</h2></div>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:16px;margin-top:32px;">
          <a href="pest-control-ivins-ut.html" class="btn btn--outline" style="text-align:center;">📍 Ivins</a>
          <a href="best-pest-control-st-george.html" class="btn btn--outline" style="text-align:center;">📍 St. George</a>
          <a href="pest-control-washington-ut.html" class="btn btn--outline" style="text-align:center;">📍 Washington</a>
          <a href="pest-control-southern-utah.html" class="btn btn--outline" style="text-align:center;">🛡️ All Southern Utah</a>
          <a href="ant-control-st-george.html" class="btn btn--outline" style="text-align:center;">🐜 Ant Control</a>
          <a href="scorpion-control-st-george.html" class="btn btn--outline" style="text-align:center;">🦂 Scorpion Control</a>
        </div>
      </div>
    </section>

    <!-- ═══ FAQ SECTION ═══ -->
    <section class="section--alt section">
      <div class="container">
        <div class="text-center reveal">
          <span class="section-label">Common Questions</span>
          <h2>Frequently Asked Questions</h2>
        </div>
        <div style="max-width:800px;margin:40px auto 0;">

        <details class="reveal" style="background:var(--off-white);border-radius:var(--radius);padding:20px 24px;margin-bottom:12px;cursor:pointer;">
          <summary style="font-family:var(--font-display);font-weight:700;font-size:1.05rem;color:var(--text-dark);">Why does Santa Clara have unique pest problems?</summary>
          <p style="margin-top:12px;color:var(--text-body);max-width:65ch;">Santa Clara sits along the Santa Clara River corridor, which provides water and habitat for pest populations. Homes near the river and bordering Ivins' desert terrain experience higher than average ant, spider, scorpion, and rodent activity compared to interior St. George neighborhoods.</p>
        </details>
        <details class="reveal" style="background:var(--off-white);border-radius:var(--radius);padding:20px 24px;margin-bottom:12px;cursor:pointer;">
          <summary style="font-family:var(--font-display);font-weight:700;font-size:1.05rem;color:var(--text-dark);">What pests are most common in Santa Clara?</summary>
          <p style="margin-top:12px;color:var(--text-body);max-width:65ch;">Ants (especially fire ants and harvester ants), black widow spiders, bark scorpions, and mice are the most frequently treated pests in Santa Clara. The river corridor also supports mosquito breeding during warmer months.</p>
        </details>
        <details class="reveal" style="background:var(--off-white);border-radius:var(--radius);padding:20px 24px;margin-bottom:12px;cursor:pointer;">
          <summary style="font-family:var(--font-display);font-weight:700;font-size:1.05rem;color:var(--text-dark);">Does Wernex offer same-day service in Santa Clara?</summary>
          <p style="margin-top:12px;color:var(--text-body);max-width:65ch;">Yes. Santa Clara is within our primary service area. We offer same-day inspections and treatment. Call (435) 673-9503.</p>
        </details>
        <details class="reveal" style="background:var(--off-white);border-radius:var(--radius);padding:20px 24px;margin-bottom:12px;cursor:pointer;">
          <summary style="font-family:var(--font-display);font-weight:700;font-size:1.05rem;color:var(--text-dark);">Are Wernex treatments safe for my pets and garden?</summary>
          <p style="margin-top:12px;color:var(--text-body);max-width:65ch;">Yes. We use an IPM-first approach with eco-friendly, low-toxicity products that are safe for families, pets, and gardens. All products are EPA-compliant, and our technicians provide specific guidance based on your property.</p>
        </details>
        </div>
      </div>
    </section>

    <!-- ═══ CTA SECTION ═══ -->
    <section class="section--dark section">
      <div class="container text-center">
        <h2>Ready to Get Started?</h2>
        <p class="mx-auto" style="margin-top:12px;color:rgba(255,255,255,0.8);">Call Wernex today for a free inspection and quote. Same-day service available throughout Southern Utah.</p>
        <div style="margin-top:28px;display:flex;gap:16px;justify-content:center;flex-wrap:wrap;">
          <a href="tel:+14356739503" class="btn btn--white">📞 (435) 673-9503</a>
          <a href="contact.html" class="btn btn--primary">Schedule Online →</a>
        </div>
      </div>
    </section>

  <!-- ═══ FOOTER ═══ -->
</BaseLayout>
