---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Wasp &amp; Bee Removal in St. George UT — Safe Nest Removal | Wernex';
const description = 'Professional wasp and bee removal in St. George, Utah. Wernex safely removes paper wasp, yellow jacket, and mud dauber nests. Same-day emergency service. Call (435) 673-9503.';
const canonical = 'https://www.wernexpestcontrol.com/wasp-removal-st-george.html';
const active = '';
const og = { "og:title": 'Wasp & Bee Removal in St. George UT — Safe Nest Removal | Wernex', "og:description": 'Professional wasp and bee removal in St. George, Utah. Wernex safely removes paper wasp, yellow jacket, and mud dauber nests. Same-day emergency service. Call (435) 673-9503.', "og:type": 'website', "og:url": 'https://www.wernexpestcontrol.com/wasp-removal-st-george.html', "og:locale": 'en_US', "og:site_name": 'Wernex Termite & Pest Control' };
const schema = `{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "@id": "https://www.wernexpestcontrol.com/#business",
      "name": "Wernex Termite & Pest Control, Inc.",
      "url": "https://www.wernexpestcontrol.com/",
      "telephone": "+1-435-673-9503",
      "email": "wernexpestcontrol@gmail.com",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "6097 Dry Fork Canyon Rd",
        "addressLocality": "Vernal",
        "addressRegion": "UT",
        "postalCode": "84078",
        "addressCountry": "US"
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "bestRating": "5",
        "ratingCount": "87"
      },
      "priceRange": "$$"
    },
    {
      "@type": "WebPage",
      "@id": "https://www.wernexpestcontrol.com/wasp-removal-st-george.html#webpage",
      "url": "https://www.wernexpestcontrol.com/wasp-removal-st-george.html",
      "name": "Wasp & Bee Removal in St. George UT \\u2014 Safe Nest Removal | Wernex",
      "isPartOf": {
        "@id": "https://www.wernexpestcontrol.com/#website"
      },
      "about": {
        "@id": "https://www.wernexpestcontrol.com/#business"
      },
      "breadcrumb": {
        "@id": "https://www.wernexpestcontrol.com/wasp-removal-st-george.html#breadcrumb"
      }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.wernexpestcontrol.com/wasp-removal-st-george.html#breadcrumb",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://www.wernexpestcontrol.com/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Wasp Removal St. George",
          "item": "https://www.wernexpestcontrol.com/wasp-removal-st-george.html"
        }
      ]
    },
    {
      "@type": "FAQPage",
      "@id": "https://www.wernexpestcontrol.com/wasp-removal-st-george.html#faq",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What types of wasps are common in St. George?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Paper wasps, yellow jackets, and mud daubers are the most common stinging insects in the St. George area. Paper wasps build umbrella-shaped nests under eaves. Yellow jackets nest in the ground or wall voids and are the most aggressive. Mud daubers build tube-shaped nests and are generally non-aggressive."
          }
        },
        {
          "@type": "Question",
          "name": "Is it safe to remove a wasp nest myself?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "DIY wasp nest removal is dangerous, especially for yellow jacket nests. Disturbed colonies can swarm and deliver multiple painful stings. People with allergies can experience life-threatening anaphylaxis. Wernex technicians use professional-grade equipment and protective gear for safe removal."
          }
        },
        {
          "@type": "Question",
          "name": "Can Wernex remove bee nests without killing the bees?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "For honeybees, we coordinate with local beekeepers for live relocation when possible. For carpenter bees, wasps, and yellow jackets, we use targeted treatments to eliminate the nest safely."
          }
        },
        {
          "@type": "Question",
          "name": "How fast can you respond to a wasp emergency?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "We offer same-day emergency wasp removal in St. George, Washington, Hurricane, and surrounding areas. Call (435) 673-9503 for immediate dispatch."
          }
        }
      ]
    }
  ]
}`;
---
<BaseLayout title={title} description={description} canonical={canonical} og={og} schema={schema} active={active}>
<!-- ═══ HERO ═══ -->
  <section class="hero" style="min-height:auto;padding:160px 0 80px;">
    <div class="hero__bg-gradient"></div>
    <div class="container">
      <div class="hero__content reveal" style="--delay:0;max-width:800px;">
        <div class="hero__pre-label">
          <span class="hero__dot"></span>
          Licensed &amp; Insured • 30+ Years
        </div>
        <h1>Wasp &amp; Bee Removal<br><span>St. George &amp; Southern Utah</span></h1>

        <!-- ═══ SEO: AI SUMMARY BLOCK ═══ -->
        <p>Wernex Termite &amp; Pest Control provides safe, professional wasp and bee removal in St. George and throughout Southern Utah. We handle paper wasps, yellow jackets, mud daubers, and carpenter bees — removing active nests, treating harborage areas, and applying preventive barrier treatments. Same-day emergency service available for aggressive nests near living areas. Licensed, insured, eco-friendly. Call (435) 673-9503.</p>

        <div class="hero__buttons" style="margin-top:28px;">
          <a href="contact.html" class="btn btn--primary">Get a Free Quote →</a>
          <a href="tel:+14356739503" class="btn btn--white">📞 (435) 673-9503</a>
        </div>
        <div class="hero__badges" style="margin-top:24px;">
          <div class="hero__badge"><div class="hero__badge-icon">✓</div><span>Licensed &amp; Insured</span></div>
          <div class="hero__badge"><div class="hero__badge-icon">🌿</div><span>Eco-Friendly</span></div>
          <div class="hero__badge"><div class="hero__badge-icon">⏱️</div><span>Same-Day Service</span></div>
          <div class="hero__badge"><div class="hero__badge-icon">🔒</div><span>Satisfaction Guaranteed</span></div>
        </div>
      </div>
    </div>
  </section>

    <section class="section">
      <div class="container">
        <div class="text-center reveal">
          <span class="section-label">Stinging Insects</span>
          <h2>Wasps &amp; Bees in Southern Utah</h2>
          <p class="mx-auto" style="margin-top:12px;color:var(--gray);">Southern Utah's warm climate supports year-round wasp activity. Nests near doorways, eaves, and play areas create a serious sting risk for families and pets.</p>
        </div>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:24px;margin-top:48px;">
          <div class="card reveal"><div class="card__body">
            <h3>📄 Paper Wasps</h3>
            <p style="color:var(--gray);">Build open-comb nests under eaves, porch ceilings, and patio covers. Mildly aggressive when disturbed. Nests can house 20–75 wasps.</p>
          </div></div>
          <div class="card reveal"><div class="card__body">
            <h3>⚠️ Yellow Jackets</h3>
            <p style="color:var(--gray);">Highly aggressive ground-nesting wasps. Colonies can contain 1,000+ workers. They attack in swarms when their nest is disturbed — the most dangerous stinging insect in Southern Utah.</p>
          </div></div>
          <div class="card reveal"><div class="card__body">
            <h3>🏗️ Carpenter Bees</h3>
            <p style="color:var(--gray);">Bore perfectly round holes into wood fascia, decks, and pergolas. Males hover aggressively but cannot sting. Females rarely sting. The real damage is structural — repeated boring weakens wood over time.</p>
          </div></div>
        </div>
      </div>
    </section>

    <section class="section--alt section">
      <div class="container">
        <div class="text-center reveal">
          <span class="section-label">Our Process</span>
          <h2>Safe, Professional Nest Removal</h2>
          <p class="mx-auto" style="margin-top:12px;color:var(--gray);">Wernex technicians wear full protective equipment and use professional-grade products to eliminate nests safely — no DIY risk, no shortcuts.</p>
        </div>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:24px;margin-top:48px;">
          <div class="card reveal"><div class="card__body"><h3>Step 1: Assessment</h3><p style="color:var(--gray);">We identify the species, locate all nests, and assess the risk level. Yellow jacket ground nests require different treatment than paper wasp eave nests.</p></div></div>
          <div class="card reveal"><div class="card__body"><h3>Step 2: Treatment &amp; Removal</h3><p style="color:var(--gray);">Targeted application directly into the nest, followed by physical nest removal once activity ceases. We treat wall voids, soffits, and ground entry points as needed.</p></div></div>
          <div class="card reveal"><div class="card__body"><h3>Step 3: Prevention</h3><p style="color:var(--gray);">Residual barrier spray on eaves, fascia, and common nesting sites discourages new nest construction throughout the season.</p></div></div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="text-center reveal"><span class="section-label">Related Services</span><h2>More Pest Solutions</h2></div>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:16px;margin-top:32px;">
          <a href="pest-control-southern-utah.html" class="btn btn--outline" style="text-align:center;">🛡️ All Southern Utah Services</a>
          <a href="scorpion-control-st-george.html" class="btn btn--outline" style="text-align:center;">🦂 Scorpion Control</a>
          <a href="ant-control-st-george.html" class="btn btn--outline" style="text-align:center;">🐜 Ant Control</a>
          <a href="pest-library.html" class="btn btn--outline" style="text-align:center;">📚 Pest Library</a>
        </div>
      </div>
    </section>

    <!-- ═══ FAQ SECTION ═══ -->
    <section class="section--alt section">
      <div class="container">
        <div class="text-center reveal">
          <span class="section-label">Common Questions</span>
          <h2>Frequently Asked Questions</h2>
        </div>
        <div style="max-width:800px;margin:40px auto 0;">

        <details class="reveal" style="background:var(--off-white);border-radius:var(--radius);padding:20px 24px;margin-bottom:12px;cursor:pointer;">
          <summary style="font-family:var(--font-display);font-weight:700;font-size:1.05rem;color:var(--text-dark);">What types of wasps are common in St. George?</summary>
          <p style="margin-top:12px;color:var(--text-body);max-width:65ch;">Paper wasps, yellow jackets, and mud daubers are the most common stinging insects in the St. George area. Paper wasps build umbrella-shaped nests under eaves. Yellow jackets nest in the ground or wall voids and are the most aggressive. Mud daubers build tube-shaped nests and are generally non-aggressive.</p>
        </details>
        <details class="reveal" style="background:var(--off-white);border-radius:var(--radius);padding:20px 24px;margin-bottom:12px;cursor:pointer;">
          <summary style="font-family:var(--font-display);font-weight:700;font-size:1.05rem;color:var(--text-dark);">Is it safe to remove a wasp nest myself?</summary>
          <p style="margin-top:12px;color:var(--text-body);max-width:65ch;">DIY wasp nest removal is dangerous, especially for yellow jacket nests. Disturbed colonies can swarm and deliver multiple painful stings. People with allergies can experience life-threatening anaphylaxis. Wernex technicians use professional-grade equipment and protective gear for safe removal.</p>
        </details>
        <details class="reveal" style="background:var(--off-white);border-radius:var(--radius);padding:20px 24px;margin-bottom:12px;cursor:pointer;">
          <summary style="font-family:var(--font-display);font-weight:700;font-size:1.05rem;color:var(--text-dark);">Can Wernex remove bee nests without killing the bees?</summary>
          <p style="margin-top:12px;color:var(--text-body);max-width:65ch;">For honeybees, we coordinate with local beekeepers for live relocation when possible. For carpenter bees, wasps, and yellow jackets, we use targeted treatments to eliminate the nest safely.</p>
        </details>
        <details class="reveal" style="background:var(--off-white);border-radius:var(--radius);padding:20px 24px;margin-bottom:12px;cursor:pointer;">
          <summary style="font-family:var(--font-display);font-weight:700;font-size:1.05rem;color:var(--text-dark);">How fast can you respond to a wasp emergency?</summary>
          <p style="margin-top:12px;color:var(--text-body);max-width:65ch;">We offer same-day emergency wasp removal in St. George, Washington, Hurricane, and surrounding areas. Call (435) 673-9503 for immediate dispatch.</p>
        </details>
        </div>
      </div>
    </section>

    <!-- ═══ CTA SECTION ═══ -->
    <section class="section--dark section">
      <div class="container text-center">
        <h2>Ready to Get Started?</h2>
        <p class="mx-auto" style="margin-top:12px;color:rgba(255,255,255,0.8);">Call Wernex today for a free inspection and quote. Same-day service available throughout Southern Utah.</p>
        <div style="margin-top:28px;display:flex;gap:16px;justify-content:center;flex-wrap:wrap;">
          <a href="tel:+14356739503" class="btn btn--white">📞 (435) 673-9503</a>
          <a href="contact.html" class="btn btn--primary">Schedule Online →</a>
        </div>
      </div>
    </section>

  <!-- ═══ FOOTER ═══ -->
</BaseLayout>
