---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Pest Control in Ivins UT — Same-Day Service &amp; Eco-Friendly Treatments | Wernex';
const description = 'Professional pest control in Ivins, Utah. Wernex serves Ivins homes and businesses near Snow Canyon with same-day inspections, eco-friendly treatments, and a satisfaction guarantee. Call (435) 673-9503.';
const canonical = 'https://www.wernexpestcontrol.com/pest-control-ivins-ut.html';
const active = '';
const og = { "og:title": 'Pest Control in Ivins UT — Same-Day Service & Eco-Friendly Treatments | Wernex', "og:description": 'Professional pest control in Ivins, Utah. Wernex serves Ivins homes and businesses near Snow Canyon with same-day inspections, eco-friendly treatments, and a satisfaction guarantee. Call (435) 673-9503.', "og:type": 'website', "og:url": 'https://www.wernexpestcontrol.com/pest-control-ivins-ut.html', "og:locale": 'en_US', "og:site_name": 'Wernex Termite & Pest Control' };
const schema = `{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "@id": "https://www.wernexpestcontrol.com/#business",
      "name": "Wernex Termite & Pest Control, Inc.",
      "url": "https://www.wernexpestcontrol.com/",
      "telephone": "+1-435-673-9503",
      "email": "wernexpestcontrol@gmail.com",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "6097 Dry Fork Canyon Rd",
        "addressLocality": "Vernal",
        "addressRegion": "UT",
        "postalCode": "84078",
        "addressCountry": "US"
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "bestRating": "5",
        "ratingCount": "87"
      },
      "priceRange": "$$"
    },
    {
      "@type": "WebPage",
      "@id": "https://www.wernexpestcontrol.com/pest-control-ivins-ut.html#webpage",
      "url": "https://www.wernexpestcontrol.com/pest-control-ivins-ut.html",
      "name": "Pest Control in Ivins UT \\u2014 Same-Day Service & Eco-Friendly Treatments | Wernex",
      "isPartOf": {
        "@id": "https://www.wernexpestcontrol.com/#website"
      },
      "about": {
        "@id": "https://www.wernexpestcontrol.com/#business"
      },
      "breadcrumb": {
        "@id": "https://www.wernexpestcontrol.com/pest-control-ivins-ut.html#breadcrumb"
      }
    },
    {
      "@type": "BreadcrumbList",
      "@id": "https://www.wernexpestcontrol.com/pest-control-ivins-ut.html#breadcrumb",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://www.wernexpestcontrol.com/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Pest Control Ivins UT",
          "item": "https://www.wernexpestcontrol.com/pest-control-ivins-ut.html"
        }
      ]
    },
    {
      "@type": "FAQPage",
      "@id": "https://www.wernexpestcontrol.com/pest-control-ivins-ut.html#faq",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Why do Ivins homes have more pest problems than other areas?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Ivins sits at the edge of the Red Cliffs Desert Reserve and Snow Canyon \\u2014 undeveloped desert terrain that harbors scorpions, spiders, and rodents. As homes expand into desert-edge lots, pests are displaced directly into living spaces. Properties backing to washes and open desert face especially high pest pressure."
          }
        },
        {
          "@type": "Question",
          "name": "What pests are most common in Ivins, Utah?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Bark scorpions, black widow spiders, fire ants, mice, and roof rats are the most common pest issues in Ivins. The rocky terrain provides ideal scorpion and spider harborage, while irrigated landscaping attracts ants and rodents."
          }
        },
        {
          "@type": "Question",
          "name": "How fast can Wernex get to my Ivins home?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Wernex offers same-day pest control service in Ivins. We're based in the St. George service area and can typically reach Ivins properties within hours of your call. Call (435) 673-9503."
          }
        },
        {
          "@type": "Question",
          "name": "Does Wernex offer ongoing pest protection plans in Ivins?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. We offer quarterly protection plans that include interior and exterior treatments, perimeter barrier sprays, and unlimited re-service calls if pests return between scheduled visits."
          }
        }
      ]
    }
  ]
}`;
---
<BaseLayout title={title} description={description} canonical={canonical} og={og} schema={schema} active={active}>
<!-- ═══ HERO ═══ -->
  <section class="hero" style="min-height:auto;padding:160px 0 80px;">
    <div class="hero__bg-gradient"></div>
    <div class="container">
      <div class="hero__content reveal" style="--delay:0;max-width:800px;">
        <div class="hero__pre-label">
          <span class="hero__dot"></span>
          Licensed &amp; Insured • 30+ Years
        </div>
        <h1>Pest Control in Ivins, Utah<br><span>Near Snow Canyon State Park</span></h1>

        <!-- ═══ SEO: AI SUMMARY BLOCK ═══ -->
        <p>Wernex Termite &amp; Pest Control provides full-service pest control in Ivins, Utah — just minutes from Snow Canyon State Park. Ivins homes bordering the desert and red rock terrain face elevated pest pressure from scorpions, spiders, ants, and rodents year-round. Wernex delivers same-day inspections, eco-friendly IPM treatments, quarterly protection plans, and a 100% satisfaction guarantee. Licensed, insured, 30+ years serving <a href="pest-control-southern-utah.html">all of Southern Utah</a>. Call (435) 673-9503.</p>

        <div class="hero__buttons" style="margin-top:28px;">
          <a href="contact.html" class="btn btn--primary">Get a Free Quote →</a>
          <a href="tel:+14356739503" class="btn btn--white">📞 (435) 673-9503</a>
        </div>
        <div class="hero__badges" style="margin-top:24px;">
          <div class="hero__badge"><div class="hero__badge-icon">✓</div><span>Licensed &amp; Insured</span></div>
          <div class="hero__badge"><div class="hero__badge-icon">🌿</div><span>Eco-Friendly</span></div>
          <div class="hero__badge"><div class="hero__badge-icon">⏱️</div><span>Same-Day Service</span></div>
          <div class="hero__badge"><div class="hero__badge-icon">🔒</div><span>Satisfaction Guaranteed</span></div>
        </div>
      </div>
    </div>
  </section>

    <section class="section">
      <div class="container">
        <div class="text-center reveal">
          <span class="section-label">Ivins Pest Challenges</span>
          <h2>Desert-Edge Living Means Year-Round Pest Pressure</h2>
          <p class="mx-auto" style="margin-top:12px;color:var(--gray);">Ivins homes sit where residential development meets raw desert — Snow Canyon, the Red Cliffs Reserve, and Kayenta's red rock terrain. That boundary line is where pest pressure is highest.</p>
        </div>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:24px;margin-top:48px;">
          <div class="card reveal"><div class="card__body"><h3>🦂 Scorpions</h3><p style="color:var(--gray);">Bark scorpions thrive in Ivins' rocky terrain and enter homes through gaps under doors and around pipes. UV blacklight detection sweeps reveal populations homeowners can't see.</p></div></div>
          <div class="card reveal"><div class="card__body"><h3>🕷️ Spiders</h3><p style="color:var(--gray);">Black widows and wolf spiders are extremely common in Ivins garages, sheds, and outdoor living spaces. Desert-edge properties see higher concentrations than interior St. George neighborhoods.</p></div></div>
          <div class="card reveal"><div class="card__body"><h3>🐀 Rodents</h3><p style="color:var(--gray);">Mice and roof rats enter Ivins homes through attic vents, garage gaps, and plumbing penetrations. Irrigated landscaping near natural desert creates ideal rodent habitat.</p></div></div>
        </div>
      </div>
    </section>

    <section class="section--dark section">
      <div class="container">
        <div class="stats-bar">
          <div class="stat reveal"><div class="stat__number">30+</div><div class="stat__label">Years in Southern Utah</div></div>
          <div class="stat reveal"><div class="stat__number">4.9★</div><div class="stat__label">Google Rating</div></div>
          <div class="stat reveal"><div class="stat__number">Same Day</div><div class="stat__label">Ivins Service Available</div></div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="text-center reveal"><span class="section-label">Nearby Service Areas</span><h2>We Also Serve</h2></div>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:16px;margin-top:32px;">
          <a href="pest-control-santa-clara-ut.html" class="btn btn--outline" style="text-align:center;">📍 Santa Clara</a>
          <a href="best-pest-control-st-george.html" class="btn btn--outline" style="text-align:center;">📍 St. George</a>
          <a href="pest-control-hurricane-ut.html" class="btn btn--outline" style="text-align:center;">📍 Hurricane</a>
          <a href="pest-control-southern-utah.html" class="btn btn--outline" style="text-align:center;">🛡️ All Southern Utah</a>
          <a href="scorpion-control-st-george.html" class="btn btn--outline" style="text-align:center;">🦂 Scorpion Control</a>
          <a href="spider-control-st-george.html" class="btn btn--outline" style="text-align:center;">🕷️ Spider Control</a>
        </div>
      </div>
    </section>

    <!-- ═══ FAQ SECTION ═══ -->
    <section class="section--alt section">
      <div class="container">
        <div class="text-center reveal">
          <span class="section-label">Common Questions</span>
          <h2>Frequently Asked Questions</h2>
        </div>
        <div style="max-width:800px;margin:40px auto 0;">

        <details class="reveal" style="background:var(--off-white);border-radius:var(--radius);padding:20px 24px;margin-bottom:12px;cursor:pointer;">
          <summary style="font-family:var(--font-display);font-weight:700;font-size:1.05rem;color:var(--text-dark);">Why do Ivins homes have more pest problems than other areas?</summary>
          <p style="margin-top:12px;color:var(--text-body);max-width:65ch;">Ivins sits at the edge of the Red Cliffs Desert Reserve and Snow Canyon — undeveloped desert terrain that harbors scorpions, spiders, and rodents. As homes expand into desert-edge lots, pests are displaced directly into living spaces. Properties backing to washes and open desert face especially high pest pressure.</p>
        </details>
        <details class="reveal" style="background:var(--off-white);border-radius:var(--radius);padding:20px 24px;margin-bottom:12px;cursor:pointer;">
          <summary style="font-family:var(--font-display);font-weight:700;font-size:1.05rem;color:var(--text-dark);">What pests are most common in Ivins, Utah?</summary>
          <p style="margin-top:12px;color:var(--text-body);max-width:65ch;">Bark scorpions, black widow spiders, fire ants, mice, and roof rats are the most common pest issues in Ivins. The rocky terrain provides ideal scorpion and spider harborage, while irrigated landscaping attracts ants and rodents.</p>
        </details>
        <details class="reveal" style="background:var(--off-white);border-radius:var(--radius);padding:20px 24px;margin-bottom:12px;cursor:pointer;">
          <summary style="font-family:var(--font-display);font-weight:700;font-size:1.05rem;color:var(--text-dark);">How fast can Wernex get to my Ivins home?</summary>
          <p style="margin-top:12px;color:var(--text-body);max-width:65ch;">Wernex offers same-day pest control service in Ivins. We're based in the St. George service area and can typically reach Ivins properties within hours of your call. Call (435) 673-9503.</p>
        </details>
        <details class="reveal" style="background:var(--off-white);border-radius:var(--radius);padding:20px 24px;margin-bottom:12px;cursor:pointer;">
          <summary style="font-family:var(--font-display);font-weight:700;font-size:1.05rem;color:var(--text-dark);">Does Wernex offer ongoing pest protection plans in Ivins?</summary>
          <p style="margin-top:12px;color:var(--text-body);max-width:65ch;">Yes. We offer quarterly protection plans that include interior and exterior treatments, perimeter barrier sprays, and unlimited re-service calls if pests return between scheduled visits.</p>
        </details>
        </div>
      </div>
    </section>

    <!-- ═══ CTA SECTION ═══ -->
    <section class="section--dark section">
      <div class="container text-center">
        <h2>Ready to Get Started?</h2>
        <p class="mx-auto" style="margin-top:12px;color:rgba(255,255,255,0.8);">Call Wernex today for a free inspection and quote. Same-day service available throughout Southern Utah.</p>
        <div style="margin-top:28px;display:flex;gap:16px;justify-content:center;flex-wrap:wrap;">
          <a href="tel:+14356739503" class="btn btn--white">📞 (435) 673-9503</a>
          <a href="contact.html" class="btn btn--primary">Schedule Online →</a>
        </div>
      </div>
    </section>

  <!-- ═══ FOOTER ═══ -->
</BaseLayout>
