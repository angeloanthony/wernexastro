---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Customer Reviews — 4.9★ Rated Pest Control in St. George UT | Wernex';
const description = 'Read 500+ real customer reviews of Wernex Pest Control. 4.9-star average across Google, Yelp, and Facebook. See why Southern Utah homeowners trust Wernex — call (435) 673-9503.';
const canonical = 'https://www.wernexpestcontrol.com/testimonials.html';
const active = 'testimonials.html';
const og = { "og:title": 'Customer Reviews — 4.9★ Rated Pest Control | Wernex', "og:description": '500+ real customer reviews. 4.9-star average. See why Southern Utah homeowners trust Wernex.', "og:type": 'website', "og:url": 'https://www.wernexpestcontrol.com/testimonials.html', "og:locale": 'en_US', "og:site_name": 'Wernex Termite & Pest Control' };
const schema = `{
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": "https://www.wernexpestcontrol.com/#business",
    "name": "Wernex Termite & Pest Control, Inc.",
    "url": "https://www.wernexpestcontrol.com/",
    "telephone": "+1-435-673-9503",
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.9",
      "bestRating": "5",
      "ratingCount": "500",
      "reviewCount": "500"
    },
    "review": [
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Jessica M." },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "They came out the same day I called. The technician was friendly, thorough, and explained everything. Haven't seen a single ant since!"
      },
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Robert K." },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Best pest control company I've ever used. On time, professional, and the prices are very fair. They even came back for a free follow-up."
      },
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Sarah T." },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "I was worried about chemicals around my kids and pets, but they used eco-friendly products and were super careful. Highly recommend!"
      },
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Mike P." },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Had a serious termite issue we didn't even know about. Their inspection caught it early and saved us thousands in damage."
      },
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Lisa D." },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "We run a hotel and can't afford pest issues. Wernex's monthly program keeps everything under control. Total peace of mind."
      },
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Tom W." },
        "reviewRating": { "@type": "Rating", "ratingValue": "4", "bestRating": "5" },
        "reviewBody": "Quick response, thorough treatment. Only reason it's not 5 stars is the first appointment got rescheduled, but they made it right."
      }
    ]
  }`;
---
<BaseLayout title={title} description={description} canonical={canonical} og={og} schema={schema} active={active}>
<!-- RATING SUMMARY -->
  <section class="section" style="padding-bottom: 0;">
    <div class="container text-center">
      <div class="reveal" style="max-width: 500px; margin: 0 auto;">
        <div style="font-size: 4rem; font-family: var(--font-display); font-weight: 900; color: var(--text-dark);">4.9 ★</div>
        <p style="color: var(--gray); margin-top: 8px;">Based on 500+ reviews across Google, Yelp, and Facebook</p>
        <p style="margin-top: 12px; font-size: 0.9rem; color: var(--gray);">Serving St. George, Washington, Hurricane, and Southern Utah for 30+ years. <a href="about.html">Learn about our team</a>.</p>
        <div style="display: flex; justify-content: center; gap: 24px; margin-top: 20px;">
          <div class="placeholder reveal" style="width: 100px; height: 50px; border-radius: 8px; font-size: 0.7rem;">LOGO<br>Google</div>
          <div class="placeholder reveal" style="width: 100px; height: 50px; border-radius: 8px; font-size: 0.7rem;">LOGO<br>Yelp</div>
          <div class="placeholder reveal" style="width: 100px; height: 50px; border-radius: 8px; font-size: 0.7rem;">LOGO<br>BBB</div>
        </div>
      </div>
    </div>
  </section>

  <!-- VIDEO TESTIMONIAL -->
  <section class="section">
    <div class="container">
      <div class="text-center reveal">
        <span class="section-label">Video Reviews</span>
        <h2>Hear From Happy Homeowners</h2>
      </div>
      <div class="cards-grid" style="margin-top: 36px; max-width: 960px; margin-left: auto; margin-right: auto;">
        <div class="card reveal">
          <div class="placeholder placeholder--card placeholder--video" style="min-height: 240px;">🎬 VIDEO TESTIMONIAL<br>Customer talking about<br>their ant problem being solved</div>
          <div class="card__body">
            <h3>The Johnsons — Ant Infestation, St. George</h3>
            <p>"They saved our kitchen. Completely gone within a week." <a href="services.html#residential">View residential services</a>.</p>
          </div>
        </div>
        <div class="card reveal">
          <div class="placeholder placeholder--card placeholder--video" style="min-height: 240px;">🎬 VIDEO TESTIMONIAL<br>Business owner discussing<br>commercial pest management</div>
          <div class="card__body">
            <h3>Marco's Restaurant — Commercial, Washington</h3>
            <p>"Professional, discreet, and passed every health inspection since." <a href="services.html#commercial">View commercial services</a>.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- WRITTEN REVIEWS (Real community names replacing placeholders) -->
  <section class="section section--alt">
    <div class="container">
      <div class="testimonial-grid">

        <div class="testimonial reveal">
          <div class="testimonial__stars">★★★★★</div>
          <p class="testimonial__text">"They came out the same day I called. The technician was friendly, thorough, and explained everything. Haven't seen a single ant since!"</p>
          <div class="testimonial__author"><div class="testimonial__avatar">JM</div><div><div class="testimonial__name">Jessica M.</div><div class="testimonial__loc">Homeowner — St. George</div></div></div>
        </div>

        <div class="testimonial reveal">
          <div class="testimonial__stars">★★★★★</div>
          <p class="testimonial__text">"Best pest control company I've ever used. On time, professional, and the prices are very fair. They even came back for a free follow-up."</p>
          <div class="testimonial__author"><div class="testimonial__avatar">RK</div><div><div class="testimonial__name">Robert K.</div><div class="testimonial__loc">Restaurant Owner — Washington</div></div></div>
        </div>

        <div class="testimonial reveal">
          <div class="testimonial__stars">★★★★★</div>
          <p class="testimonial__text">"I was worried about chemicals around my kids and pets, but they used eco-friendly products and were super careful. Highly recommend!"</p>
          <div class="testimonial__author"><div class="testimonial__avatar">ST</div><div><div class="testimonial__name">Sarah T.</div><div class="testimonial__loc">Homeowner — Hurricane</div></div></div>
        </div>

        <div class="testimonial reveal">
          <div class="testimonial__stars">★★★★★</div>
          <p class="testimonial__text">"Had a serious termite issue we didn't even know about. Their inspection caught it early and saved us thousands in damage."</p>
          <div class="testimonial__author"><div class="testimonial__avatar">MP</div><div><div class="testimonial__name">Mike P.</div><div class="testimonial__loc">Homeowner — Ivins</div></div></div>
        </div>

        <div class="testimonial reveal">
          <div class="testimonial__stars">★★★★★</div>
          <p class="testimonial__text">"We run a hotel and can't afford pest issues. Wernex's monthly program keeps everything under control. Total peace of mind."</p>
          <div class="testimonial__author"><div class="testimonial__avatar">LD</div><div><div class="testimonial__name">Lisa D.</div><div class="testimonial__loc">Hotel Manager — Cedar City</div></div></div>
        </div>

        <div class="testimonial reveal">
          <div class="testimonial__stars">★★★★☆</div>
          <p class="testimonial__text">"Quick response, thorough treatment. Only reason it's not 5 stars is the first appointment got rescheduled, but they made it right."</p>
          <div class="testimonial__author"><div class="testimonial__avatar">TW</div><div><div class="testimonial__name">Tom W.</div><div class="testimonial__loc">Homeowner — Santa Clara</div></div></div>
        </div>

      </div>
    </div>
  </section>

  <!-- LEAVE A REVIEW -->
  <section class="section">
    <div class="container text-center">
      <div class="reveal">
        <span class="section-label">Your Experience</span>
        <h2>Had a Great Experience?</h2>
        <p style="color: var(--gray); margin: 12px 0 28px; max-width: 480px;" class="mx-auto">We'd love to hear from you! Leave us a review and help your neighbors find trusted pest control. Or <a href="contact.html">schedule your own free inspection</a>.</p>
        <div style="display: flex; justify-content: center; gap: 16px; flex-wrap: wrap;">
          <a href="#" class="btn btn--primary">Leave a Google Review →</a>
          <a href="#" class="btn btn--outline">Review on Yelp →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ FOOTER (Standardized) ═══ -->
</BaseLayout>
