---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Pest Control in Washington UT — Same-Day Inspections & Eco-Friendly | Wernex';
const description = 'Wernex serves Washington, Utah with professional pest control — same-day inspections, termite treatments, rodent exclusion, and eco-friendly options. Call (435) 673-9503.';
const canonical = 'https://www.wernexpestcontrol.com/pest-control-washington-ut.html';
const active = '';
const og = { "og:title": 'Pest Control in Washington UT — Same-Day Service | Wernex', "og:description": 'Wernex serves Washington, Utah with professional pest control — same-day inspections, termite treatments, rodent exclusion, and eco-friendly options. Call (435) 673-9503.', "og:type": 'website', "og:url": 'https://www.wernexpestcontrol.com/pest-control-washington-ut.html', "og:locale": 'en_US', "og:site_name": 'Wernex Termite & Pest Control' };
const schema = `{
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "LocalBusiness",
        "@id": "https://www.wernexpestcontrol.com/#business",
        "name": "Wernex Termite & Pest Control, Inc.",
        "url": "https://www.wernexpestcontrol.com/",
        "telephone": "+1-435-673-9503",
        "email": "wernexpestcontrol@gmail.com",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "6097 Dry Fork Canyon Rd",
          "addressLocality": "Vernal",
          "addressRegion": "UT",
          "postalCode": "84078",
          "addressCountry": "US"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": 40.4555,
          "longitude": -109.5287
        },
        "areaServed": [{"@type":"City","name":"Washington","sameAs":"https://en.wikipedia.org/wiki/Washington,_Utah"},{"@type":"City","name":"St. George"},{"@type":"City","name":"Washington"},{"@type":"City","name":"Hurricane"},{"@type":"City","name":"Ivins"},{"@type":"City","name":"Santa Clara"},{"@type":"City","name":"LaVerkin"},{"@type":"City","name":"Cedar City"}],
        "priceRange": "$",
        "image": "https://www.wernexpestcontrol.com/images/Logo.webp",
        "logo": "https://www.wernexpestcontrol.com/images/Logo.webp",
        "description": "Professional pest control serving Washington, Utah. Same-day inspections, eco-friendly treatments, termite solutions, and rodent control."
      },
      {
        "@type": "FAQPage",
        "@id": "https://www.wernexpestcontrol.com/pest-control-washington-ut.html#faq",
        "mainEntity": [{"@type":"Question","name":"Does Wernex provide pest control in Washington, Utah?","acceptedAnswer":{"@type":"Answer","text":"Yes. Wernex Termite & Pest Control services Washington, UT and is located nearby in the St. George metro area. Same-day inspections and emergency service are available. Call (435) 673-9503."}},{"@type":"Question","name":"What pest problems are common in Washington, UT?","acceptedAnswer":{"@type":"Answer","text":"Washington residents frequently encounter subterranean termites (especially in newer construction), bark scorpions, black widow spiders, ants, mice, and seasonal mosquitoes near the Virgin River and irrigation channels in the Washington Fields area."}},{"@type":"Question","name":"Does Wernex do termite inspections for Washington home sales?","acceptedAnswer":{"@type":"Answer","text":"Yes. Wernex provides WDI (Wood-Destroying Insect) inspections required for many real estate transactions in Washington City. We deliver a detailed report with findings and treatment recommendations."}},{"@type":"Question","name":"Are Wernex treatments safe around kids and pets?","acceptedAnswer":{"@type":"Answer","text":"Yes. Wernex uses EPA-compliant, low-toxicity products following an Integrated Pest Management (IPM) approach. Your technician will advise on any precautions specific to the products used in your home."}},{"@type":"Question","name":"How often should I schedule pest control in Washington?","acceptedAnswer":{"@type":"Answer","text":"For Washington's climate, quarterly treatments provide year-round protection. High-pressure situations like scorpions or active termites may require monthly service initially. Wernex will recommend the right frequency after your free inspection."}}]
      }
    ]
  }`;
---
<BaseLayout title={title} description={description} canonical={canonical} og={og} schema={schema} active={active}>
<!-- HERO / AI SUMMARY -->
  <section class="section--dark" style="padding-top:140px;">
    <div class="container">
      <span class="section-label">Serving Washington, Utah</span>
      <h1>Pest Control in Washington, Utah — Licensed, Local &amp; Trusted</h1>
      <p style="max-width:70ch;color:rgba(255,255,255,0.85);font-size:1.1rem;margin-top:16px;line-height:1.7;">
        Wernex Termite &amp; Pest Control provides residential and commercial pest management throughout Washington, Utah. Just minutes from St. George, Washington is one of the fastest-growing cities in <a href="pest-control-southern-utah.html" style="color:var(--lime);">Southern Utah</a> — and rapid development brings increased pest activity. From termites in new construction to scorpions in established neighborhoods near the Washington Fields area, Wernex delivers same-day inspections, eco-friendly treatments, and a 100% satisfaction guarantee backed by 30+ years of local experience. Call (435) 673-9503.
      </p>
      <div style="margin-top:28px;display:flex;gap:14px;flex-wrap:wrap;">
        <a href="contact.html" class="btn btn--primary">Get a Free Quote</a>
        <a href="tel:+14356739503" class="btn btn--outline"  style="border-color:var(--lime);color:var(--lime);">📞 (435) 673-9503</a>
      </div>
    </div>
  </section>

  <!-- TRUST BADGES -->
  <section class="section" style="padding:32px 0;">
    <div class="container" style="display:flex;flex-wrap:wrap;gap:24px;justify-content:center;">
      <div class="hero__badge"><div class="hero__badge-icon">⭐</div><span>4.5-Star Rated</span></div>
      <div class="hero__badge"><div class="hero__badge-icon">🌿</div><span>Eco-Friendly</span></div>
      <div class="hero__badge"><div class="hero__badge-icon">⏱️</div><span>Same-Day Service</span></div>
      <div class="hero__badge"><div class="hero__badge-icon">🔒</div><span>30-Day Guarantee</span></div>
    </div>
  </section>


  <section class="section">
    <div class="container">
      <span class="section-label">Local Knowledge</span>
      <h2>Why Washington, Utah Homes Need Expert Pest Control</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:40px;margin-top:32px;">
        <div>
          <p style="line-height:1.8;margin-bottom:20px;">Washington is one of the fastest-growing cities in Utah, and new development across the Washington Fields area is pushing wildlife and pests into residential neighborhoods. Construction activity disturbs established colonies of ants and termites, sending them into nearby homes.</p>
          <p style="line-height:1.8;margin-bottom:20px;">The city's location between St. George and Hurricane — along the Virgin River corridor — creates ideal conditions for mosquitoes, rodents, and scorpions. Black widows are frequently found in garages, storage sheds, and cinder-block walls throughout older Washington neighborhoods.</p>
          <p style="line-height:1.8;">Wernex brings 30+ years of Southern Utah experience to Washington. Our technicians know the construction styles, soil types, and seasonal patterns that influence pest behavior in this specific area. We tailor every treatment to Washington's conditions — not a generic template.</p>
        </div>
        <div>
          <h3 style="margin-bottom:20px;">Washington's Top Pest Threats</h3>
          <div style="display:grid;gap:12px;">
            <div class="reveal" style="padding:16px 20px;background:var(--off-white);border-radius:var(--radius);display:flex;align-items:center;gap:14px;">
              <span style="font-size:1.5rem;">🪵</span><div><strong>Termites</strong> — New construction in sandy soil is a prime target</div>
            </div>
            <div class="reveal" style="padding:16px 20px;background:var(--off-white);border-radius:var(--radius);display:flex;align-items:center;gap:14px;">
              <span style="font-size:1.5rem;">🦂</span><div><strong>Scorpions</strong> — Bark scorpions in neighborhoods near the lava fields</div>
            </div>
            <div class="reveal" style="padding:16px 20px;background:var(--off-white);border-radius:var(--radius);display:flex;align-items:center;gap:14px;">
              <span style="font-size:1.5rem;">🕷️</span><div><strong>Black Widows</strong> — Common in garages, sheds, and block walls</div>
            </div>
            <div class="reveal" style="padding:16px 20px;background:var(--off-white);border-radius:var(--radius);display:flex;align-items:center;gap:14px;">
              <span style="font-size:1.5rem;">🐀</span><div><strong>Rodents</strong> — Pack rats and mice near agricultural areas</div>
            </div>
            <div class="reveal" style="padding:16px 20px;background:var(--off-white);border-radius:var(--radius);display:flex;align-items:center;gap:14px;">
              <span style="font-size:1.5rem;">🦟</span><div><strong>Mosquitoes</strong> — Seasonal pressure near the Virgin River</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <span class="section-label">Our Services</span>
      <h2>Pest Control Services for Washington Residents</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:24px;margin-top:32px;">
        <div class="reveal" style="background:#fff;border-radius:var(--radius-lg);padding:32px;border:1px solid var(--gray-light);">
          <div style="font-size:2rem;margin-bottom:12px;">🏠</div>
          <h3>Home Protection Plans</h3>
          <p style="margin-top:8px;color:var(--text-body);line-height:1.7;">Quarterly and monthly residential programs with interior and exterior barrier sprays, targeted baiting, and eco-friendly options for families.</p>
        </div>
        <div class="reveal" style="background:#fff;border-radius:var(--radius-lg);padding:32px;border:1px solid var(--gray-light);">
          <div style="font-size:2rem;margin-bottom:12px;">🪵</div>
          <h3>Termite Protection</h3>
          <p style="margin-top:8px;color:var(--text-body);line-height:1.7;">Termidor liquid barriers, WDI inspections for home sales, pre-construction treatments for new Washington builds, and annual monitoring.</p>
        </div>
        <div class="reveal" style="background:#fff;border-radius:var(--radius-lg);padding:32px;border:1px solid var(--gray-light);">
          <div style="font-size:2rem;margin-bottom:12px;">🦂</div>
          <h3>Scorpion Control</h3>
          <p style="margin-top:8px;color:var(--text-body);line-height:1.7;">Targeted scorpion treatments, UV detection sweeps, and entry-point sealing to keep bark scorpions out of your Washington home.</p>
        </div>
        <div class="reveal" style="background:#fff;border-radius:var(--radius-lg);padding:32px;border:1px solid var(--gray-light);">
          <div style="font-size:2rem;margin-bottom:12px;">🐀</div>
          <h3>Rodent Exclusion</h3>
          <p style="margin-top:8px;color:var(--text-body);line-height:1.7;">Full exclusion sealing, snap-trap and bait-station programs, and ongoing monitoring to keep mice and pack rats out permanently.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--dark">
    <div class="container text-center">
      <span class="section-label">The Wernex Difference</span>
      <h2 style="color:var(--white);">30+ Years Protecting Southern Utah</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:32px;margin-top:40px;max-width:900px;margin-left:auto;margin-right:auto;">
        <div class="reveal"><div style="font-size:2.5rem;">🏆</div><p style="color:rgba(255,255,255,0.8);margin-top:8px;">BBB A+ Accredited</p></div>
        <div class="reveal"><div style="font-size:2.5rem;">🌿</div><p style="color:rgba(255,255,255,0.8);margin-top:8px;">IPM-First Approach</p></div>
        <div class="reveal"><div style="font-size:2.5rem;">📋</div><p style="color:rgba(255,255,255,0.8);margin-top:8px;">State-Licensed Technicians</p></div>
        <div class="reveal"><div style="font-size:2.5rem;">🔄</div><p style="color:rgba(255,255,255,0.8);margin-top:8px;">Free Re-Service in 30 Days</p></div>
      </div>
    </div>
  </section>

  <!-- FAQ SECTION -->
  <section class="section section--alt" id="faq">
    <div class="container">
      <span class="section-label">Frequently Asked Questions</span>
      <h2 style="margin-bottom:32px;">Washington, UT Pest Control — Common Questions</h2>
      <div style="max-width:800px;">
        <details class="reveal" style="background:#fff;border-radius:var(--radius);padding:20px 24px;margin-bottom:12px;border:1px solid var(--gray-light);cursor:pointer;">
          <summary style="font-family:var(--font-display);font-weight:700;font-size:1.05rem;color:var(--text-dark);">Does Wernex provide pest control in Washington, Utah?</summary>
          <p style="margin-top:12px;color:var(--text-body);line-height:1.7;">Yes. Wernex Termite & Pest Control services Washington, UT and is located nearby in the St. George metro area. Same-day inspections and emergency service are available. Call (435) 673-9503.</p>
        </details>
        <details class="reveal" style="background:#fff;border-radius:var(--radius);padding:20px 24px;margin-bottom:12px;border:1px solid var(--gray-light);cursor:pointer;">
          <summary style="font-family:var(--font-display);font-weight:700;font-size:1.05rem;color:var(--text-dark);">What pest problems are common in Washington, UT?</summary>
          <p style="margin-top:12px;color:var(--text-body);line-height:1.7;">Washington residents frequently encounter subterranean termites (especially in newer construction), bark scorpions, black widow spiders, ants, mice, and seasonal mosquitoes near the Virgin River and irrigation channels in the Washington Fields area.</p>
        </details>
        <details class="reveal" style="background:#fff;border-radius:var(--radius);padding:20px 24px;margin-bottom:12px;border:1px solid var(--gray-light);cursor:pointer;">
          <summary style="font-family:var(--font-display);font-weight:700;font-size:1.05rem;color:var(--text-dark);">Does Wernex do termite inspections for Washington home sales?</summary>
          <p style="margin-top:12px;color:var(--text-body);line-height:1.7;">Yes. Wernex provides WDI (Wood-Destroying Insect) inspections required for many real estate transactions in Washington City. We deliver a detailed report with findings and treatment recommendations.</p>
        </details>
        <details class="reveal" style="background:#fff;border-radius:var(--radius);padding:20px 24px;margin-bottom:12px;border:1px solid var(--gray-light);cursor:pointer;">
          <summary style="font-family:var(--font-display);font-weight:700;font-size:1.05rem;color:var(--text-dark);">Are Wernex treatments safe around kids and pets?</summary>
          <p style="margin-top:12px;color:var(--text-body);line-height:1.7;">Yes. Wernex uses EPA-compliant, low-toxicity products following an Integrated Pest Management (IPM) approach. Your technician will advise on any precautions specific to the products used in your home.</p>
        </details>
        <details class="reveal" style="background:#fff;border-radius:var(--radius);padding:20px 24px;margin-bottom:12px;border:1px solid var(--gray-light);cursor:pointer;">
          <summary style="font-family:var(--font-display);font-weight:700;font-size:1.05rem;color:var(--text-dark);">How often should I schedule pest control in Washington?</summary>
          <p style="margin-top:12px;color:var(--text-body);line-height:1.7;">For Washington's climate, quarterly treatments provide year-round protection. High-pressure situations like scorpions or active termites may require monthly service initially. Wernex will recommend the right frequency after your free inspection.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- INTERNAL LINKS -->
  <section class="section">
    <div class="container">
      <span class="section-label">Explore More</span>
      <h2 style="margin-bottom:24px;">Related Services &amp; Areas</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:16px;max-width:900px;">
        <a href="pest-control-southern-utah.html" class="reveal" style="display:block;padding:18px 22px;background:var(--off-white);border-radius:var(--radius);border:1px solid var(--gray-light);font-family:var(--font-display);font-weight:600;color:var(--green-light);transition:var(--transition);">🛡️ Pest Control Across Southern Utah</a>
        <a href="index.html" class="reveal" style="display:block;padding:18px 22px;background:var(--off-white);border-radius:var(--radius);border:1px solid var(--gray-light);font-family:var(--font-display);font-weight:600;color:var(--green-light);transition:var(--transition);">🏠 Wernex Home — St. George Pest Control</a>
        <a href="services.html" class="reveal" style="display:block;padding:18px 22px;background:var(--off-white);border-radius:var(--radius);border:1px solid var(--gray-light);font-family:var(--font-display);font-weight:600;color:var(--green-light);transition:var(--transition);">🛠️ Full Service List</a>
        <a href="pest-control-hurricane-ut.html" class="reveal" style="display:block;padding:18px 22px;background:var(--off-white);border-radius:var(--radius);border:1px solid var(--gray-light);font-family:var(--font-display);font-weight:600;color:var(--green-light);transition:var(--transition);">📍 Pest Control in Hurricane, UT</a>
        <a href="pest-control-santa-clara-ut.html" class="reveal" style="display:block;padding:18px 22px;background:var(--off-white);border-radius:var(--radius);border:1px solid var(--gray-light);font-family:var(--font-display);font-weight:600;color:var(--green-light);transition:var(--transition);">📍 Pest Control in Santa Clara, UT</a>
        <a href="termite-control-st-george.html" class="reveal" style="display:block;padding:18px 22px;background:var(--off-white);border-radius:var(--radius);border:1px solid var(--gray-light);font-family:var(--font-display);font-weight:600;color:var(--green-light);transition:var(--transition);">🪵 Termite Control — St. George</a>
        <a href="scorpion-control-st-george.html" class="reveal" style="display:block;padding:18px 22px;background:var(--off-white);border-radius:var(--radius);border:1px solid var(--gray-light);font-family:var(--font-display);font-weight:600;color:var(--green-light);transition:var(--transition);">🦂 Scorpion Control — Southern Utah</a>
        <a href="commercial-pest-control-southern-utah.html" class="reveal" style="display:block;padding:18px 22px;background:var(--off-white);border-radius:var(--radius);border:1px solid var(--gray-light);font-family:var(--font-display);font-weight:600;color:var(--green-light);transition:var(--transition);">🏢 Commercial Pest Control</a>
        <a href="contact.html" class="reveal" style="display:block;padding:18px 22px;background:var(--off-white);border-radius:var(--radius);border:1px solid var(--gray-light);font-family:var(--font-display);font-weight:600;color:var(--green-light);transition:var(--transition);">📞 Schedule an Appointment</a>
      </div>
    </div>
  </section>

  <!-- CTA BOTTOM -->
  <section class="section--dark" style="padding:60px 0;text-align:center;">
    <div class="container">
      <h2 style="color:var(--white);">Washington, UT Pest Problems? Call Wernex Today.</h2>
      <p style="color:rgba(255,255,255,0.8);margin:16px auto 28px;max-width:55ch;">Free inspections, same-day service, and a 30-day satisfaction guarantee. Over 30 years protecting Southern Utah homes and businesses.</p>
      <div style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap;">
        <a href="contact.html" class="btn btn--primary btn--lg">Schedule Free Inspection</a>
        <a href="tel:+14356739503" class="btn btn--outline btn--lg" style="border-color:var(--lime);color:var(--lime);">📞 (435) 673-9503</a>
      </div>
    </div>
  </section>

  <!-- ═══ FOOTER ═══ -->
</BaseLayout>
